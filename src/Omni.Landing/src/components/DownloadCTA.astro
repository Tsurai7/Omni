---
interface Props {
  macUrl: string;
  windowsUrl: string;
  apiUrl?: string;
}

const { macUrl, windowsUrl, apiUrl } = Astro.props;
const signInUrl = apiUrl ? `${apiUrl}/auth/google` : null;
---

<section class="section download-cta" id="download">
  <div class="download-cta__inner reveal">
    <h2 class="download-cta__title">
      Ready to take control<br />of your time?
    </h2>
    <p class="download-cta__sub">
      Free to use. No account required to get started.
    </p>

    <div class="download-cta__actions">
      {
        signInUrl && (
          <a class="btn btn--primary" href={signInUrl}>
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="none"
            >
              <path
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                fill="#fff"
              />
              <path
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                fill="#fff"
              />
              <path
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
                fill="#fff"
              />
              <path
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                fill="#fff"
              />
            </svg>
            Sign in & Download
          </a>
        )
      }

      <a class="btn btn--outline download-btn--mac" href={macUrl}>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
          ></path>
        </svg>
        Download for macOS
      </a>

      <a class="btn btn--outline download-btn--win" href={windowsUrl}>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M3 5.548l7.548-1.038V11.5H3V5.548zm0 7.452h7.548v7.038L3 18.96V13zm8.452-8.596L21 3v8.5h-9.548V4.404zm0 9.096H21V21l-9.548-1.316V13.5z"
          ></path>
        </svg>
        Download for Windows
      </a>
    </div>
  </div>
</section>
