---
import type { Release } from "@/config/changelog";

interface Props {
  releases: Release[];
}

const { releases } = Astro.props;
---

<section class="section changelog" id="changelog">
  <div class="section__header reveal">
    <p class="section-label">Changelog</p>
    <h2 class="section-title">What's new</h2>
  </div>

  <div class="changelog__list">
    {
      releases.map((release, i) => (
        <details class="changelog__entry reveal" open={i === 0}>
          <summary class="changelog__summary">
            <span class="changelog__version">{release.version}</span>
            <span class="changelog__date">{release.date}</span>
            <svg
              class="changelog__chevron"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M6 9l6 6 6-6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </summary>
          <ul class="changelog__highlights">
            {release.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </details>
      ))
    }
  </div>
</section>
