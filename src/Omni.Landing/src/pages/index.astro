---
import "../styles/global.css";
import { downloads } from "@/config/downloads";
import { features } from "@/config/features";
import { reviews } from "@/config/reviews";
import { changelog } from "@/config/changelog";

import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Features from "@/components/Features.astro";
import Reviews from "@/components/Reviews.astro";
import Changelog from "@/components/Changelog.astro";
import DownloadCTA from "@/components/DownloadCTA.astro";

const { macUrl, windowsUrl, versionLabel } = downloads;
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "";

const title = "Omni — Your Productivity Assistant";
const description =
  "Track sessions, stay focused, and understand your work patterns. Download Omni for macOS or Windows.";
---

<!doctype html>
<html lang="en" data-detected-os="other">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Detect OS before first paint to style the right download button -->
    <script is:inline>
      (function () {
        var ua = navigator.userAgent || "";
        var os = /Mac|iPhone|iPad|iPod/i.test(ua)
          ? "mac"
          : /Windows/i.test(ua)
            ? "windows"
            : "other";
        document.documentElement.dataset.detectedOs = os;
      })();
    </script>
  </head>

  <body>
    <Nav />

    <Hero
      macUrl={macUrl}
      windowsUrl={windowsUrl}
      versionLabel={versionLabel}
      apiUrl={apiUrl || undefined}
    />

    <Features features={features} />

    <Reviews reviews={reviews} />

    <Changelog releases={changelog} />

    <DownloadCTA
      macUrl={macUrl}
      windowsUrl={windowsUrl}
      apiUrl={apiUrl || undefined}
    />

    <footer class="site-footer">
      <span class="site-footer__brand">Omni</span>
      <span class="site-footer__copy">© {new Date().getFullYear()}</span>
    </footer>

    <!-- Scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
