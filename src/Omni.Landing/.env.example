# Copied into the environment at build time (Astro public env).
#
# Stable “latest” GitHub Release assets (replace OWNER/REPO; filenames must match uploads):
# PUBLIC_DOWNLOAD_MAC_URL=https://github.com/OWNER/REPO/releases/latest/download/Omni-macos.dmg
# PUBLIC_DOWNLOAD_WIN_URL=https://github.com/OWNER/REPO/releases/latest/download/Omni-windows.exe
PUBLIC_DOWNLOAD_MAC_URL=https://example.com/Omni-macos.dmg
PUBLIC_DOWNLOAD_WIN_URL=https://example.com/Omni-windows.exe
# Optional label shown under the buttons
PUBLIC_APP_VERSION=1.0.0
