<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.TasksPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource ProductivityPageBackground}">
    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,52,20,0" Spacing="0">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Tasks" Style="{StaticResource ProductivityHeadline}"/>
                    <Label Text="Synced across devices" Style="{StaticResource ProductivityCaption}"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="+ Add"
                        Style="{StaticResource ProductivityPillButton}"
                        VerticalOptions="Center"
                        Clicked="OnAddTaskClicked"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Task List -->
        <RefreshView x:Name="RefreshView" Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}"
                     RefreshColor="{StaticResource ProductivityFocus}">
            <CollectionView x:Name="TaskList"
                            ItemsSource="{Binding Tasks}"
                            SelectionMode="None"
                            Margin="20,0,20,32">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16" Margin="0,0,0,10"
                                BackgroundColor="{StaticResource ProductivityCardBackground}"
                                Stroke="{StaticResource ProductivityCardStroke}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <!-- Status indicator dot -->
                                <Ellipse Grid.Column="0"
                                         WidthRequest="8" HeightRequest="8"
                                         VerticalOptions="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding StatusColor}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Title + Status -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource ProductivityBody}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Status}"
                                           Style="{StaticResource ProductivityCaption}"
                                           TextTransform="Capitalize"/>
                                </VerticalStackLayout>
                                <!-- Done button -->
                                <Button Grid.Column="2"
                                        Text="Done"
                                        Style="{StaticResource ProductivitySecondaryButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkDoneCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding IsPending}"
                                        VerticalOptions="Center"
                                        Padding="12,0"
                                        HeightRequest="34"/>
                                <!-- Delete button -->
                                <Button Grid.Column="3"
                                        Text="✕"
                                        Style="{StaticResource ProductivitySecondaryButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                                        CommandParameter="{Binding .}"
                                        VerticalOptions="Center"
                                        Padding="10,0"
                                        HeightRequest="34"
                                        WidthRequest="40"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="12" Padding="0,80">
                        <Label Text="📋"
                               FontSize="48"
                               HorizontalOptions="Center"/>
                        <Label Text="No tasks yet"
                               Style="{StaticResource ProductivityTitle}"
                               HorizontalOptions="Center"/>
                        <Label Text="Tap + Add to create your first task."
                               Style="{StaticResource ProductivityCaption}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
