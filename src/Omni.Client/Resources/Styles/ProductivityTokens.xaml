<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Productivity semantic colors (dark theme; Apple-inspired calm + Rize clarity) -->
    <Color x:Key="ProductivityPageBackground">#0F0F0F</Color>
    <Color x:Key="ProductivityCardBackground">#1E1E1E</Color>
    <Color x:Key="ProductivityCardStroke">#2D2D2D</Color>
    <Color x:Key="ProductivityTextPrimary">#E0E0E0</Color>
    <Color x:Key="ProductivityTextSecondary">#A0A0A0</Color>
    <Color x:Key="ProductivityTextTertiary">#808080</Color>
    <Color x:Key="ProductivityTextMuted">#606060</Color>

    <Color x:Key="ProductivityFocus">#4ECCA3</Color>
    <Color x:Key="ProductivityNeutral">#6B9AC4</Color>
    <Color x:Key="ProductivityDistraction">#E07A5F</Color>
    <Color x:Key="ProductivitySuccess">#4ECCA3</Color>
    <Color x:Key="ProductivityCtaBackground">#4ECCA3</Color>
    <Color x:Key="ProductivityCtaText">#0F0F0F</Color>

    <!-- Spacing (8px base) -->
    <x:Double x:Key="ProductivitySpacingXs">4</x:Double>
    <x:Double x:Key="ProductivitySpacingSm">8</x:Double>
    <x:Double x:Key="ProductivitySpacingMd">12</x:Double>
    <x:Double x:Key="ProductivitySpacingLg">16</x:Double>
    <x:Double x:Key="ProductivitySpacingXl">20</x:Double>
    <x:Double x:Key="ProductivitySpacing2Xl">24</x:Double>

    <!-- Corner radii -->
    <x:Double x:Key="ProductivityRadiusSm">10</x:Double>
    <x:Double x:Key="ProductivityRadiusMd">12</x:Double>
    <x:Double x:Key="ProductivityRadiusLg">15</x:Double>

    <!-- Card padding -->
    <Thickness x:Key="ProductivityCardPadding">20,16</Thickness>
    <Thickness x:Key="ProductivityCardMargin">20,0,20,16</Thickness>

    <!-- Typography (reference; fonts still from MauiProgram) -->
    <Style TargetType="Label" x:Key="ProductivityCaption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextSecondary}"/>
    </Style>
    <Style TargetType="Label" x:Key="ProductivityBody">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
    </Style>
    <Style TargetType="Label" x:Key="ProductivityBodyBold">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" x:Key="ProductivityTitle">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" x:Key="ProductivityHeadline">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>
    <Style TargetType="Label" x:Key="ProductivityDisplay">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityFocus}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- Primary CTA button (Start Focus, Recover Focus) -->
    <Style TargetType="Button" x:Key="ProductivityCtaButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ProductivityCtaBackground}"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityCtaText}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusSm}"/>
        <Setter Property="HeightRequest" Value="48"/>
    </Style>

    <!-- Secondary / outline button -->
    <Style TargetType="Button" x:Key="ProductivitySecondaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ProductivityCardStroke}"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusSm}"/>
        <Setter Property="HeightRequest" Value="44"/>
    </Style>
</ResourceDictionary>
