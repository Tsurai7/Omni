<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEMANTIC COLORS — dark theme defaults
         These values are overwritten at runtime by ThemeService when the user
         switches theme. Views must use DynamicResource (not StaticResource)
         for any of these keys so the live update propagates.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="ProductivityPageBackground">#07070A</Color>
    <Color x:Key="ProductivityCardBackground">#0F0F12</Color>
    <Color x:Key="ProductivityCardBackgroundElevated">#16161B</Color>

    <!-- Borders — MAUI ARGB hex: #AARRGGBB -->
    <Color x:Key="ProductivityCardStroke">#12FFFFFF</Color>
    <Color x:Key="ProductivityCardStrokeSubtle">#0AFFFFFF</Color>

    <!-- Text -->
    <Color x:Key="ProductivityTextPrimary">#F0F0F4</Color>
    <Color x:Key="ProductivityTextSecondary">#8E8EA0</Color>
    <Color x:Key="ProductivityTextTertiary">#4A4A5A</Color>
    <Color x:Key="ProductivityTextMuted">#333340</Color>

    <!-- Purple UI accent -->
    <Color x:Key="ProductivityUIAccent">#8B5CF6</Color>
    <Color x:Key="ProductivityUIAccentSoft">#2E8B5CF6</Color>
    <Color x:Key="ProductivityUIAccentGlow">#598B5CF6</Color>

    <!-- Mint / productivity semantic colors -->
    <Color x:Key="ProductivityFocus">#4ECCA3</Color>
    <Color x:Key="ProductivityFocusDim">#2A7A61</Color>
    <Color x:Key="ProductivityNeutral">#6B9AC4</Color>
    <Color x:Key="ProductivityDistraction">#E07A5F</Color>
    <Color x:Key="ProductivityAmber">#F5A623</Color>
    <Color x:Key="ProductivitySuccess">#4ECCA3</Color>

    <!-- CTA -->
    <Color x:Key="ProductivityCtaBackground">#4ECCA3</Color>
    <Color x:Key="ProductivityCtaText">#0F1210</Color>

    <!-- Danger -->
    <Color x:Key="ProductivityDanger">#E05C5C</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GRADIENT BRUSHES
         ═══════════════════════════════════════════════════════════════════════ -->

    <LinearGradientBrush x:Key="ProductivityPageGradient"
                         StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#1A8B5CF6" Offset="0.0"/>
        <GradientStop Color="#FF07070A" Offset="0.38"/>
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SPACING — 8px base grid
         ═══════════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="ProductivitySpacingXs">4</x:Double>
    <x:Double x:Key="ProductivitySpacingSm">8</x:Double>
    <x:Double x:Key="ProductivitySpacingMd">12</x:Double>
    <x:Double x:Key="ProductivitySpacingLg">16</x:Double>
    <x:Double x:Key="ProductivitySpacingXl">20</x:Double>
    <x:Double x:Key="ProductivitySpacing2Xl">24</x:Double>
    <x:Double x:Key="ProductivitySpacing3Xl">32</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CORNER RADII
         ═══════════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="ProductivityRadiusXs">8</x:Double>
    <x:Int32  x:Key="ProductivityRadiusXsInt">8</x:Int32>
    <x:Double x:Key="ProductivityRadiusSm">12</x:Double>
    <x:Int32  x:Key="ProductivityRadiusSmInt">12</x:Int32>
    <x:Double x:Key="ProductivityRadiusMd">16</x:Double>
    <x:Int32  x:Key="ProductivityRadiusMdInt">16</x:Int32>
    <x:Double x:Key="ProductivityRadiusLg">20</x:Double>
    <x:Int32  x:Key="ProductivityRadiusLgInt">20</x:Int32>
    <x:Double x:Key="ProductivityRadiusXl">28</x:Double>
    <x:Int32  x:Key="ProductivityRadiusXlInt">28</x:Int32>
    <x:Double x:Key="ProductivityRadiusPill">100</x:Double>
    <x:Int32  x:Key="ProductivityRadiusPillInt">100</x:Int32>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CARD LAYOUT HELPERS
         ═══════════════════════════════════════════════════════════════════════ -->
    <Thickness x:Key="ProductivityCardPadding">20,18</Thickness>
    <Thickness x:Key="ProductivityCardPaddingCompact">16,14</Thickness>
    <Thickness x:Key="ProductivityCardMargin">20,0,20,14</Thickness>
    <Thickness x:Key="ProductivityCardMarginSm">20,0,20,10</Thickness>
    <Thickness x:Key="ProductivityPagePadding">20,12</Thickness>

    <!-- ═══════════════════════════════════════════════════════════════════════
         TYPOGRAPHY — Inter font family
         NOTE: color setters use DynamicResource so theme switches propagate.
         ═══════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Label" x:Key="ProductivityUILabel">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityUIAccent}"/>
        <Setter Property="CharacterSpacing" Value="1.5"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityOverline">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextTertiary}"/>
        <Setter Property="CharacterSpacing" Value="1.2"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityCaption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextSecondary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBody">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBodyBold">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBodySecondary">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextSecondary}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityTitle">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityHeadline">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityDisplay">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityFocus}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterBold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityMetric">
        <Setter Property="FontSize" Value="56"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterBold"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         BUTTONS — color setters use DynamicResource
         ═══════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Button" x:Key="ProductivityCtaButton">
        <Setter Property="BackgroundColor" Value="{DynamicResource ProductivityCtaBackground}"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityCtaText}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="Padding" Value="20,0"/>
    </Style>

    <Style TargetType="Button" x:Key="ProductivitySecondaryButton">
        <Setter Property="BackgroundColor" Value="{DynamicResource ProductivityCardBackgroundElevated}"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextPrimary}"/>
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="BorderColor" Value="{DynamicResource ProductivityCardStroke}"/>
        <Setter Property="BorderWidth" Value="1"/>
    </Style>

    <Style TargetType="Button" x:Key="ProductivityPillButton">
        <Setter Property="BackgroundColor" Value="{DynamicResource ProductivityUIAccentSoft}"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityUIAccent}"/>
        <Setter Property="FontFamily" Value="InterSemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusPillInt}"/>
        <Setter Property="HeightRequest" Value="38"/>
        <Setter Property="Padding" Value="18,0"/>
    </Style>

    <Style TargetType="Button" x:Key="ProductivitySegmentButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityTextSecondary}"/>
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusPillInt}"/>
        <Setter Property="HeightRequest" Value="38"/>
        <Setter Property="Padding" Value="18,0"/>
    </Style>

    <Style TargetType="Button" x:Key="ProductivityDangerButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{DynamicResource ProductivityDanger}"/>
        <Setter Property="FontFamily" Value="InterMedium"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="46"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SIDEBAR NAVIGATION
         ═══════════════════════════════════════════════════════════════════════ -->

    <x:Double x:Key="SidebarWidth">220</x:Double>
    <x:Double x:Key="SidebarItemHeight">44</x:Double>
    <x:Double x:Key="SidebarHeaderHeight">64</x:Double>
    <x:Double x:Key="SidebarFooterHeight">72</x:Double>

    <Color x:Key="SidebarItemActiveBg">#1A8B5CF6</Color>
    <Color x:Key="SidebarItemPressedBg">#0D8B5CF6</Color>
    <Color x:Key="SidebarBackground">#0F0F12</Color>

</ResourceDictionary>
