<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEMANTIC COLORS — dark theme
         Inspired by Apple's depth/clarity + Rize's calm data aesthetic
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="ProductivityPageBackground">#111113</Color>
    <Color x:Key="ProductivityCardBackground">#1A1A1F</Color>
    <Color x:Key="ProductivityCardBackgroundElevated">#222228</Color>
    <Color x:Key="ProductivityCardStroke">#2A2A32</Color>
    <Color x:Key="ProductivityCardStrokeSubtle">#222229</Color>

    <!-- Text -->
    <Color x:Key="ProductivityTextPrimary">#F0F0F2</Color>
    <Color x:Key="ProductivityTextSecondary">#9898A8</Color>
    <Color x:Key="ProductivityTextTertiary">#66667A</Color>
    <Color x:Key="ProductivityTextMuted">#44444F</Color>

    <!-- Accent / state colors -->
    <Color x:Key="ProductivityFocus">#4ECCA3</Color>
    <Color x:Key="ProductivityFocusDim">#2A7A61</Color>
    <Color x:Key="ProductivityNeutral">#6B9AC4</Color>
    <Color x:Key="ProductivityDistraction">#E07A5F</Color>
    <Color x:Key="ProductivityAmber">#F5A623</Color>
    <Color x:Key="ProductivitySuccess">#4ECCA3</Color>

    <!-- CTA -->
    <Color x:Key="ProductivityCtaBackground">#4ECCA3</Color>
    <Color x:Key="ProductivityCtaText">#0F1210</Color>

    <!-- Danger -->
    <Color x:Key="ProductivityDanger">#E05C5C</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SPACING — 8px base grid
         ═══════════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="ProductivitySpacingXs">4</x:Double>
    <x:Double x:Key="ProductivitySpacingSm">8</x:Double>
    <x:Double x:Key="ProductivitySpacingMd">12</x:Double>
    <x:Double x:Key="ProductivitySpacingLg">16</x:Double>
    <x:Double x:Key="ProductivitySpacingXl">20</x:Double>
    <x:Double x:Key="ProductivitySpacing2Xl">24</x:Double>
    <x:Double x:Key="ProductivitySpacing3Xl">32</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CORNER RADII — generous curves for a softer feel
         ═══════════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="ProductivityRadiusXs">8</x:Double>
    <x:Int32  x:Key="ProductivityRadiusXsInt">8</x:Int32>
    <x:Double x:Key="ProductivityRadiusSm">12</x:Double>
    <x:Int32  x:Key="ProductivityRadiusSmInt">12</x:Int32>
    <x:Double x:Key="ProductivityRadiusMd">16</x:Double>
    <x:Int32  x:Key="ProductivityRadiusMdInt">16</x:Int32>
    <x:Double x:Key="ProductivityRadiusLg">20</x:Double>
    <x:Int32  x:Key="ProductivityRadiusLgInt">20</x:Int32>
    <x:Double x:Key="ProductivityRadiusXl">28</x:Double>
    <x:Int32  x:Key="ProductivityRadiusXlInt">28</x:Int32>
    <x:Double x:Key="ProductivityRadiusPill">100</x:Double>
    <x:Int32  x:Key="ProductivityRadiusPillInt">100</x:Int32>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CARD LAYOUT HELPERS
         ═══════════════════════════════════════════════════════════════════════ -->
    <Thickness x:Key="ProductivityCardPadding">20,18</Thickness>
    <Thickness x:Key="ProductivityCardPaddingCompact">16,14</Thickness>
    <Thickness x:Key="ProductivityCardMargin">20,0,20,14</Thickness>
    <Thickness x:Key="ProductivityCardMarginSm">20,0,20,10</Thickness>
    <Thickness x:Key="ProductivityPagePadding">20,12</Thickness>

    <!-- ═══════════════════════════════════════════════════════════════════════
         TYPOGRAPHY
         Scale: Overline 10 · Caption 12 · Body 14 · Title 16 · Headline 22 · Display 32 · Metric 56
         ═══════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Label" x:Key="ProductivityOverline">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextTertiary}"/>
        <Setter Property="CharacterSpacing" Value="1.2"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityCaption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextSecondary}"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBody">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBodyBold">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityBodySecondary">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextSecondary}"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityTitle">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityHeadline">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="ProductivityDisplay">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityFocus}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- Large metric number — score, big counters -->
    <Style TargetType="Label" x:Key="ProductivityMetric">
        <Setter Property="FontSize" Value="56"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         BUTTONS
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Primary CTA — mint green fill -->
    <Style TargetType="Button" x:Key="ProductivityCtaButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ProductivityCtaBackground}"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityCtaText}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="Padding" Value="20,0"/>
    </Style>

    <!-- Secondary / ghost button -->
    <Style TargetType="Button" x:Key="ProductivitySecondaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ProductivityCardStroke}"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="16,0"/>
    </Style>

    <!-- Pill / chip button (small quick-actions) -->
    <Style TargetType="Button" x:Key="ProductivityPillButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ProductivityCardBackgroundElevated}"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityFocus}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusPillInt}"/>
        <Setter Property="HeightRequest" Value="38"/>
        <Setter Property="Padding" Value="18,0"/>
    </Style>

    <!-- Danger button -->
    <Style TargetType="Button" x:Key="ProductivityDangerButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource ProductivityDanger}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProductivityRadiusMdInt}"/>
        <Setter Property="HeightRequest" Value="46"/>
    </Style>

</ResourceDictionary>
