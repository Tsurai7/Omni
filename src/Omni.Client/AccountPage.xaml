<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.AccountPage"
             Title="Account"
             BackgroundColor="{StaticResource ProductivityPageBackground}">
    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20">
            <Border Margin="0,0,0,16" Padding="24"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20">
                    <Label Text="Account" Style="{StaticResource ProductivityHeadline}" HorizontalOptions="Center"/>
                    <Label Text="Manage your profile and productivity settings" Style="{StaticResource ProductivityCaption}" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="1" Color="{StaticResource ProductivityCardStroke}" Margin="0,8,0,8"/>

                    <Label Text="Email" Style="{StaticResource ProductivityCaption}"/>
                    <Label x:Name="EmailLabel" Text="-" Style="{StaticResource ProductivityBody}" Margin="0,0,0,8"/>

                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                                       Color="{StaticResource ProductivityFocus}" HorizontalOptions="Center"/>

                    <Button x:Name="SignOutButton" Text="Sign out" Style="{StaticResource ProductivityCtaButton}"
                            Margin="0,16,0,0" Clicked="OnSignOutClicked"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Productivity preferences" Style="{StaticResource ProductivityTitle}" Margin="0,8,0,12"/>
            <Border Margin="0,0,0,16" Padding="16"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Daily focus goal (min)" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Used on Home for progress ring" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Picker Grid.Column="1" x:Name="DailyGoalPicker" Title="Goal"
                                TextColor="{StaticResource ProductivityTextPrimary}"
                                BackgroundColor="{StaticResource ProductivityCardStroke}"
                                WidthRequest="100" VerticalOptions="Center"
                                SelectedIndexChanged="OnDailyGoalChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource ProductivityCardStroke}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Notification intensity" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="How often to nudge during focus" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Picker Grid.Column="1" x:Name="NotificationIntensityPicker" Title="Intensity"
                                TextColor="{StaticResource ProductivityTextPrimary}"
                                BackgroundColor="{StaticResource ProductivityCardStroke}"
                                WidthRequest="120" VerticalOptions="Center"
                                SelectedIndexChanged="OnNotificationIntensityChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource ProductivityCardStroke}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Show streak on Home" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Display daily streak count" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="StreakVisibleSwitch" IsToggled="{Binding StreakVisible}"
                                OnColor="{StaticResource ProductivityFocus}" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource ProductivityCardStroke}"/>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Focus hours window" Style="{StaticResource ProductivityBody}"/>
                        <Label Text="Quiet hours for nudges (e.g. 09:00–17:00). Coming soon." Style="{StaticResource ProductivityCaption}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="Security" Style="{StaticResource ProductivityTitle}" Margin="0,8,0,12"/>
            <Border Margin="0,0,0,8" Padding="16" BackgroundColor="{StaticResource ProductivityCardStroke}" Stroke="{StaticResource ProductivityCardStroke}" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusSm}"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Change password" Style="{StaticResource ProductivityBody}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Soon" Style="{StaticResource ProductivityCaption}" VerticalOptions="Center"/>
                </Grid>
            </Border>
            <Border Margin="0,0,0,24" Padding="16" BackgroundColor="{StaticResource ProductivityCardStroke}" Stroke="{StaticResource ProductivityCardStroke}" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusSm}"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Delete account" Style="{StaticResource ProductivityBody}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Soon" Style="{StaticResource ProductivityCaption}" VerticalOptions="Center"/>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
