<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.AccountPage"
             Title="Account"
             BackgroundColor="#0F0F0F">
    <ScrollView>
        <Frame CornerRadius="15"
               Margin="20"
               VerticalOptions="Start"
               BackgroundColor="#1E1E1E"
               BorderColor="#2D2D2D"
               Padding="24"
               HasShadow="True">
            <VerticalStackLayout Spacing="20">
                <Label Text="Account"
                       FontSize="28"
                       TextColor="#E0E0E0"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Manage your profile and security"
                       FontSize="14"
                       TextColor="#A0A0A0"
                       HorizontalOptions="Center"/>
                <BoxView HeightRequest="1" Color="#2D2D2D" Margin="0,8,0,8"/>

                <!-- User info -->
                <Label Text="Email" TextColor="#A0A0A0" FontSize="14"/>
                <Label x:Name="EmailLabel"
                       Text="-"
                       FontSize="16"
                       TextColor="#E0E0E0"
                       Margin="0,0,0,8"/>

                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="#4ECCA3"
                                   HorizontalOptions="Center"/>

                <!-- Sign out -->
                <Button x:Name="SignOutButton"
                        Text="Sign out"
                        BackgroundColor="#4ECCA3"
                        TextColor="#0F0F0F"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="48"
                        Margin="0,16,0,0"
                        Clicked="OnSignOutClicked"/>

                <BoxView HeightRequest="1" Color="#2D2D2D" Margin="0,16,0,8"/>
                <Label Text="Coming soon"
                       FontSize="12"
                       TextColor="#606060"
                       HorizontalOptions="Center"/>

                <!-- Placeholders -->
                <Frame CornerRadius="10" Padding="16" BackgroundColor="#2D2D2D" BorderColor="#2D2D2D">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Change password" TextColor="#A0A0A0" FontSize="15" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Soon" TextColor="#606060" FontSize="13" VerticalOptions="Center"/>
                    </Grid>
                </Frame>
                <Frame CornerRadius="10" Padding="16" BackgroundColor="#2D2D2D" BorderColor="#2D2D2D">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Delete account" TextColor="#A0A0A0" FontSize="15" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Soon" TextColor="#606060" FontSize="13" VerticalOptions="Center"/>
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </Frame>
    </ScrollView>
</ContentPage>
