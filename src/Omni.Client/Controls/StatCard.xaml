<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.Controls.StatCard">

    <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
            Stroke="{StaticResource ProductivityCardStroke}"
            StrokeThickness="1" Padding="14,12">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
        </Border.StrokeShape>
        <VerticalStackLayout Spacing="3">
            <Label x:Name="ValueLabel"
                   FontSize="18" FontAttributes="Bold"/>
            <Label x:Name="CaptionLabel"
                   Style="{StaticResource ProductivityCaption}"/>
        </VerticalStackLayout>
    </Border>

</ContentView>
