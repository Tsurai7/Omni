<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.Controls.SidebarFooter">

    <VerticalStackLayout Spacing="0">

        <!-- Divider -->
        <BoxView HeightRequest="1"
                 BackgroundColor="{DynamicResource ProductivityCardStroke}"
                 HorizontalOptions="Fill"/>

        <!-- User info row -->
        <Grid ColumnDefinitions="Auto,*"
              HeightRequest="{StaticResource SidebarFooterHeight}"
              Padding="16,0"
              ColumnSpacing="0">

            <!-- Avatar circle -->
            <Border Grid.Column="0"
                    WidthRequest="34" HeightRequest="34"
                    BackgroundColor="{DynamicResource ProductivityFocusDim}"
                    Stroke="Transparent" StrokeThickness="0"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="17"/>
                </Border.StrokeShape>
                <Label x:Name="AvatarInitials"
                       Text="?"
                       FontSize="13"
                       FontFamily="InterSemiBold"
                       TextColor="{DynamicResource ProductivityFocus}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Email -->
            <Label x:Name="EmailLabel"
                   Grid.Column="1"
                   Text="Loading…"
                   Style="{StaticResource ProductivityCaption}"
                   LineBreakMode="TailTruncation"
                   VerticalOptions="Center"
                   Margin="10,0,0,0"/>

        </Grid>
    </VerticalStackLayout>

</ContentView>
