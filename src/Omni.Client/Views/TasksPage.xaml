<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Omni.Client.Presentation.ViewModels"
             xmlns:local="clr-namespace:Omni.Client"
             xmlns:taskModels="clr-namespace:Omni.Client.Models.Task"
             x:Class="Omni.Client.TasksPage"
             x:DataType="vm:TasksViewModel"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <StaticResource Key="ProductivityPageGradient"/>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,24,20,0" Spacing="0">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Tasks" Style="{StaticResource ProductivityHeadline}"/>
                    <Label Text="{Binding ProgressSummary}" Style="{StaticResource ProductivityCaption}"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="+ Add"
                        Style="{StaticResource ProductivityPillButton}"
                        VerticalOptions="Center"
                        Clicked="OnAddTaskClicked"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Filter pills -->
        <ScrollView Grid.Row="1" Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Padding="0,10,0,6">
            <HorizontalStackLayout Padding="16,0" Spacing="8">
                <Button Text="All"
                        BackgroundColor="{Binding FilterAllBg}"
                        TextColor="{Binding FilterAllFg}"
                        FontAttributes="Bold" FontSize="13"
                        HeightRequest="34" CornerRadius="100"
                        Padding="16,0"
                        Clicked="OnFilterAll"/>
                <Button Text="{Binding FilterTodoLabel}"
                        BackgroundColor="{Binding FilterTodoBg}"
                        TextColor="{Binding FilterTodoFg}"
                        FontAttributes="Bold" FontSize="13"
                        HeightRequest="34" CornerRadius="100"
                        Padding="16,0"
                        Clicked="OnFilterTodo"/>
                <Button Text="{Binding FilterActiveLabel}"
                        BackgroundColor="{Binding FilterActiveBg}"
                        TextColor="{Binding FilterActiveFg}"
                        FontAttributes="Bold" FontSize="13"
                        HeightRequest="34" CornerRadius="100"
                        Padding="16,0"
                        Clicked="OnFilterActive"/>
                <Button Text="{Binding FilterDoneLabel}"
                        BackgroundColor="{Binding FilterDoneBg}"
                        TextColor="{Binding FilterDoneFg}"
                        FontAttributes="Bold" FontSize="13"
                        HeightRequest="34" CornerRadius="100"
                        Padding="16,0"
                        Clicked="OnFilterDone"/>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Task list -->
        <ScrollView Grid.Row="2" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,4,16,100" Spacing="0">

                <!-- Global empty state -->
                <VerticalStackLayout IsVisible="{Binding HasNoTasks}"
                                     HorizontalOptions="Center"
                                     Padding="20,60" Spacing="12">
                    <Label Text="No tasks yet"
                           Style="{StaticResource ProductivityBody}"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource ProductivityTextSecondary}"/>
                    <Label Text="Tap + Add to create your first task"
                           Style="{StaticResource ProductivityCaption}"
                           HorizontalOptions="Center" Opacity="0.6"/>
                </VerticalStackLayout>

                <!-- ── TO DO section ─────────────────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding ShowTodoSection}" Spacing="0">

                    <Grid ColumnDefinitions="*,Auto" Padding="2,8,2,10">
                        <Label Grid.Column="0" Text="TO DO"
                               Style="{StaticResource ProductivityUILabel}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding TodoCount}"
                               FontSize="11" FontFamily="InterMedium"
                               TextColor="{StaticResource ProductivityTextMuted}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding TodoTasks}">
                        <BindableLayout.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" Padding="0,16" Spacing="4">
                                <Label Text="No to-do tasks" Style="{StaticResource ProductivityCaption}"
                                       HorizontalOptions="Center" Opacity="0.6"/>
                            </VerticalStackLayout>
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="taskModels:TaskDisplayItem">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Delete" BackgroundColor="#E05C5C"
                                                       Invoked="OnDeleteTaskRequested"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
                                            Stroke="{StaticResource ProductivityCardStroke}"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditTaskRequested"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="0">
                                            <BoxView Grid.Column="0" Color="{Binding PriorityColor}" VerticalOptions="Fill"/>
                                            <VerticalStackLayout Grid.Column="1" Padding="14,12,8,12" Spacing="5">
                                                <Label Text="{Binding Title}"
                                                       Style="{StaticResource ProductivityBody}"
                                                       LineBreakMode="WordWrap" MaxLines="2"/>
                                                <HorizontalStackLayout Spacing="4" IsVisible="{Binding HasDueDate}">
                                                    <Label Text="📅" FontSize="10"/>
                                                    <Label Text="{Binding DueDateLabel}"
                                                           TextColor="{Binding DueDateColor}" FontSize="11"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                            <!-- Priority badge (tap to cycle) -->
                                            <Button Grid.Column="2"
                                                    Text="{Binding PriorityLabel}"
                                                    TextColor="{Binding PriorityColor}"
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{Binding PriorityColor}"
                                                    BorderWidth="1"
                                                    CornerRadius="4"
                                                    FontSize="10"
                                                    FontAttributes="Bold"
                                                    CharacterSpacing="0.8"
                                                    Padding="7,0"
                                                    Margin="0,10,12,0"
                                                    HeightRequest="24"
                                                    VerticalOptions="Start"
                                                    Clicked="OnCyclePriorityRequested"/>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ── IN PROGRESS section ───────────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding ShowInProgressSection}" Spacing="0">

                    <Grid ColumnDefinitions="*,Auto" Padding="2,16,2,10">
                        <Label Grid.Column="0" Text="IN PROGRESS"
                               Style="{StaticResource ProductivityUILabel}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding InProgressCount}"
                               FontSize="11" FontFamily="InterMedium"
                               TextColor="{StaticResource ProductivityTextMuted}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding InProgressTasks}">
                        <BindableLayout.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" Padding="0,16" Spacing="4">
                                <Label Text="Nothing in progress" Style="{StaticResource ProductivityCaption}"
                                       HorizontalOptions="Center" Opacity="0.6"/>
                            </VerticalStackLayout>
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="taskModels:TaskDisplayItem">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Delete" BackgroundColor="#E05C5C"
                                                       Invoked="OnDeleteTaskRequested"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
                                            Stroke="{StaticResource ProductivityCardStroke}"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditTaskRequested"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="0">
                                            <BoxView Grid.Column="0" Color="{Binding PriorityColor}" VerticalOptions="Fill"/>
                                            <VerticalStackLayout Grid.Column="1" Padding="14,12,8,12" Spacing="5">
                                                <Label Text="{Binding Title}"
                                                       Style="{StaticResource ProductivityBody}"
                                                       LineBreakMode="WordWrap" MaxLines="2"/>
                                                <HorizontalStackLayout Spacing="4" IsVisible="{Binding HasDueDate}">
                                                    <Label Text="📅" FontSize="10"/>
                                                    <Label Text="{Binding DueDateLabel}"
                                                           TextColor="{Binding DueDateColor}" FontSize="11"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="2"
                                                    Text="{Binding PriorityLabel}"
                                                    TextColor="{Binding PriorityColor}"
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{Binding PriorityColor}"
                                                    BorderWidth="1"
                                                    CornerRadius="4"
                                                    FontSize="10"
                                                    FontAttributes="Bold"
                                                    CharacterSpacing="0.8"
                                                    Padding="7,0"
                                                    Margin="0,10,12,0"
                                                    HeightRequest="24"
                                                    VerticalOptions="Start"
                                                    Clicked="OnCyclePriorityRequested"/>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ── DONE section ──────────────────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding ShowDoneSection}" Spacing="0">

                    <Grid ColumnDefinitions="*,Auto" Padding="2,16,2,10">
                        <Label Grid.Column="0" Text="DONE"
                               Style="{StaticResource ProductivityUILabel}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding DoneCount}"
                               FontSize="11" FontFamily="InterMedium"
                               TextColor="{StaticResource ProductivityTextMuted}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Collapse toggle (only visible in All filter) -->
                    <Button Text="{Binding DoneToggleLabel}"
                            IsVisible="{Binding ShowDoneToggle}"
                            Clicked="OnToggleDoneExpanded"
                            BackgroundColor="#1E1E24"
                            TextColor="#66667A"
                            FontSize="12"
                            HeightRequest="34"
                            CornerRadius="10"
                            HorizontalOptions="Start"
                            Padding="12,0"
                            Margin="0,0,0,10"/>

                    <!-- Done task cards -->
                    <VerticalStackLayout IsVisible="{Binding ShowDoneItems}"
                                         Spacing="8"
                                         BindableLayout.ItemsSource="{Binding DoneTasks}">
                        <BindableLayout.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" Padding="0,16" Spacing="4">
                                <Label Text="No completed tasks" Style="{StaticResource ProductivityCaption}"
                                       HorizontalOptions="Center" Opacity="0.6"/>
                            </VerticalStackLayout>
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="taskModels:TaskDisplayItem">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Delete" BackgroundColor="#E05C5C"
                                                       Invoked="OnDeleteTaskRequested"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
                                            Stroke="{StaticResource ProductivityCardStroke}"
                                            StrokeThickness="1"
                                            Opacity="0.65">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditTaskRequested"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="0">
                                            <BoxView Grid.Column="0" Color="#4ECCA3" VerticalOptions="Fill"/>
                                            <VerticalStackLayout Grid.Column="1" Padding="14,12,8,12" Spacing="5">
                                                <Label Text="{Binding Title}"
                                                       Style="{StaticResource ProductivityBody}"
                                                       LineBreakMode="WordWrap" MaxLines="2"
                                                       TextDecorations="Strikethrough"
                                                       Opacity="0.5"/>
                                                <HorizontalStackLayout Spacing="4" IsVisible="{Binding HasDueDate}" Opacity="0.5">
                                                    <Label Text="📅" FontSize="10"/>
                                                    <Label Text="{Binding DueDateLabel}"
                                                           TextColor="{Binding DueDateColor}" FontSize="11"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2"
                                                    Padding="7,3" BackgroundColor="Transparent"
                                                    Stroke="#4ECCA3" StrokeThickness="1"
                                                    Margin="0,10,12,0"
                                                    VerticalOptions="Start"
                                                    Opacity="0.4">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding PriorityLabel}"
                                                       TextColor="#4ECCA3"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="0.8"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
