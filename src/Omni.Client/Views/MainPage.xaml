<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Omni.Client.Controls"
             x:Class="Omni.Client.MainPage"
             Title="Home"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <StaticResource Key="ProductivityPageGradient"/>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">
        <!-- Network error banner (sits above scroll, animates in/out) -->
        <controls:NetworkErrorBanner x:Name="MainNetworkBanner"
                                     Grid.Row="0"
                                     Margin="0,0,0,0"/>

    <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="0,0,0,24" Spacing="0">

                <!-- ═══ Header ═══════════════════════════════════════════════ -->
                <Grid ColumnDefinitions="*,Auto" Padding="20,24,20,16">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Omni" Style="{StaticResource ProductivityHeadline}"/>
                        <Label Text="{Binding DayLabel}"
                               Style="{StaticResource ProductivityCaption}"/>
                    </VerticalStackLayout>
                    <!-- Streak badge — purple accent pill matching landing .badge style -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource ProductivityUIAccentSoft}"
                            Stroke="{StaticResource ProductivityUIAccentGlow}"
                            StrokeThickness="1"
                            Padding="12,6"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusPill}"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                            <Label Text="🔥" FontSize="13" VerticalOptions="Center"/>
                            <Label Text="{Binding StreakDays, StringFormat='{0}d'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource ProductivityTextPrimary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ Focus Score Hero ══════════════════════════════════════ -->
                <Border Margin="20,0,20,14"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1" Padding="24,22">
                    <Border.Shadow>
                        <Shadow Brush="#8B5CF6" Offset="0,4" Radius="28" Opacity="0.14"/>
                    </Border.Shadow>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="TODAY'S FOCUS SCORE"
                                   Style="{StaticResource ProductivityUILabel}"/>
                            <Label x:Name="ScoreNumberLabel"
                                   Text="{Binding FocusScore}"
                                   FontSize="56"
                                   FontAttributes="Bold"
                                   TextColor="{Binding FocusScoreColor}"/>
                            <Label Text="{Binding FocusScoreLabel}"
                                   Style="{StaticResource ProductivityBodySecondary}"/>
                            <!-- Goal progress bar -->
                            <VerticalStackLayout Spacing="5" Margin="0,4,0,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding GoalProgressLabel}"
                                           Style="{StaticResource ProductivityCaption}"/>
                                    <Label Grid.Column="1" Text="{Binding GoalPercentLabel}"
                                           Style="{StaticResource ProductivityCaption}"
                                           TextColor="{StaticResource ProductivityFocus}"/>
                                </Grid>
                                <ProgressBar Progress="{Binding GoalProgress}"
                                             ProgressColor="{StaticResource ProductivityFocus}"
                                             HeightRequest="4"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                        <!-- Ring -->
                        <GraphicsView x:Name="ScoreRingView"
                                      Grid.Column="1"
                                      WidthRequest="130" HeightRequest="130"
                                      VerticalOptions="Center"
                                      Margin="16,0,0,0"/>
                    </Grid>
                </Border>

                <!-- ═══ Now Card (current app) ════════════════════════════════ -->
                <Border Margin="20,0,20,14"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1" Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- State dot -->
                        <BoxView WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" VerticalOptions="Center"
                                 Color="{Binding NowStateColor}" Margin="0,0,12,0"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="NOW" Style="{StaticResource ProductivityOverline}"/>
                            <Label Text="{Binding NowDisplayName}"
                                   Style="{StaticResource ProductivityBodyBold}"
                                   LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="{Binding NowActivityState}"
                               Style="{StaticResource ProductivityCaption}"
                               TextColor="{Binding NowStateColor}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ═══ Daily Stats Row (3 columns) ═══════════════════════════ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="20,0,20,14">
                    <!-- Focus Time -->
                    <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="14,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TodayFocusMinutes}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource ProductivityFocus}"/>
                            <Label Text="Focus" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Sessions Today -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="14,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding SessionsToday}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource ProductivityNeutral}"/>
                            <Label Text="Sessions" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Streak -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="14,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding StreakDays}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource ProductivityAmber}"/>
                            <Label Text="Streak" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ AI Recommendation Card ════════════════════════════════ -->
                <Border Margin="20,0,20,14"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityUIAccentGlow}"
                        StrokeThickness="1" Padding="18,16">
                    <Border.Shadow>
                        <Shadow Brush="#8B5CF6" Offset="0,0" Radius="22" Opacity="0.12"/>
                    </Border.Shadow>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                        <Label Grid.Row="0" Text="AI INSIGHT"
                               Style="{StaticResource ProductivityUILabel}"/>
                        <Label Grid.Row="1" Text="{Binding NextBestActionText}"
                               Style="{StaticResource ProductivityBody}"
                               Margin="0,6,0,0"
                               LineBreakMode="WordWrap"/>
                        <Button Grid.Column="1" Grid.RowSpan="2"
                                Text="Go →"
                                Style="{StaticResource ProductivityPillButton}"
                                Command="{Binding NextBestActionCommand}"
                                VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ═══ Quick Actions ═════════════════════════════════════════ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="20,0,20,14">
                    <Button Text="▶  Start Session"
                            Style="{StaticResource ProductivityCtaButton}"
                            Clicked="OnStartSessionClicked"/>
                    <Button Grid.Column="1"
                            Text="＋  Add Task"
                            Style="{StaticResource ProductivitySecondaryButton}"
                            Clicked="OnAddTaskClicked"/>
                </Grid>

                <!-- ═══ Top Apps Today ═════════════════════════════════════════ -->
                <VerticalStackLayout Margin="20,0,20,0" Spacing="0">
                    <Label Text="ACTIVITY" Style="{StaticResource ProductivityUILabel}" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <Label Text="Active Now" Style="{StaticResource ProductivityTitle}"/>
                        <Label Grid.Column="1" Text="{Binding TotalTrackedTime}"
                               Style="{StaticResource ProductivityCaption}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <CollectionView x:Name="AppUsageList"
                                    IsGrouped="True"
                                    ItemsSource="{Binding GroupedApps}">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="0,12,0,6" BackgroundColor="Transparent">
                                    <HorizontalStackLayout Spacing="10">
                                        <BoxView Color="{Binding CategoryColor}"
                                                 WidthRequest="3" HeightRequest="14"
                                                 VerticalOptions="Center" CornerRadius="2"/>
                                        <Label Text="{Binding Category}"
                                               Style="{StaticResource ProductivityBodyBold}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,12" Margin="0,0,0,8"
                                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                                        Stroke="{StaticResource ProductivityCardStroke}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusSm}"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto,8">
                                        <Label Text="{Binding AppName}"
                                               Style="{StaticResource ProductivityBody}"
                                               LineBreakMode="TailTruncation"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding FormattedTime}"
                                               TextColor="{StaticResource ProductivityFocus}"
                                               FontSize="13" FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                        <BoxView Grid.Column="2"
                                                 WidthRequest="3" HeightRequest="28"
                                                 Color="{Binding CategoryColor}"
                                                 CornerRadius="2"
                                                 VerticalOptions="Center"
                                                 Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" Padding="0,40" Spacing="12">
                                <Label Text="No active apps tracked yet"
                                       Style="{StaticResource ProductivityBodySecondary}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Switch to any app and it will appear here"
                                       Style="{StaticResource ProductivityCaption}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
    </Grid>
</ContentPage>
