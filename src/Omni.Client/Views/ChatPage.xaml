<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Omni.Client.Presentation.ViewModels"
             xmlns:local="clr-namespace:Omni.Client"
             xmlns:chatModels="clr-namespace:Omni.Client.Models.Chat"
             x:Class="Omni.Client.ChatPage"
             x:DataType="vm:ChatViewModel"
             Shell.NavBarIsVisible="False"
             Background="{DynamicResource ProductivityPageGradient}">
    
    
    

    <Grid RowDefinitions="Auto,*,Auto" x:Name="RootGrid">

        <!-- ── Header ────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,24,20,12">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Omni Coach"
                       Style="{StaticResource ProductivityHeadline}"/>
                <Label Text="Your AI productivity coach"
                       Style="{StaticResource ProductivityCaption}"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="History"
                    Style="{StaticResource ProductivitySecondaryButton}"
                    Clicked="OnHistoryClicked"
                    VerticalOptions="Center"
                    Padding="14,0"
                    HeightRequest="34"/>
        </Grid>

        <!--
            CollectionView must sit directly in the Grid row — never inside a ScrollView.
            A CollectionView nested in a ScrollView collapses to zero height in MAUI.
        -->
        <CollectionView x:Name="MessageList"
                        Grid.Row="1"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None"
                        ItemsUpdatingScrollMode="KeepLastItemInView">

            <!-- Welcome screen / starters — shown when conversation is empty -->
            <CollectionView.Header>
                <VerticalStackLayout IsVisible="{Binding ShowStarters}"
                                     Spacing="20"
                                     Padding="24,32,24,24">

                    <Border WidthRequest="64" HeightRequest="64"
                            HorizontalOptions="Center"
                            BackgroundColor="{DynamicResource ProductivityUIAccentSoft}"
                            Stroke="{DynamicResource ProductivityUIAccentGlow}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="32"/>
                        </Border.StrokeShape>
                        <Label Text="✦"
                               FontSize="28"
                               TextColor="{DynamicResource ProductivityUIAccent}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Hey, I'm Omni Coach"
                               Style="{StaticResource ProductivityTitle}"
                               HorizontalOptions="Center"/>
                        <Label Text="I know your tasks, sessions, and focus patterns.&#10;Ask me anything about your productivity."
                               Style="{StaticResource ProductivityCaption}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Starters: BindableLayout avoids a nested CollectionView -->
                    <VerticalStackLayout IsVisible="{Binding ShowStarters}" Spacing="10">
                        <Label Text="Start with..."
                               Style="{StaticResource ProductivityUILabel}"
                               Margin="0,0,0,2"/>
                        <VerticalStackLayout Spacing="8"
                                             BindableLayout.ItemsSource="{Binding Starters}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="local:StarterViewModel">
                                    <Border Padding="14,12"
                                            BackgroundColor="{DynamicResource ProductivityCardBackground}"
                                            Stroke="{DynamicResource ProductivityCardStroke}"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnStarterTapped"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Label Grid.Column="0"
                                                   Text="{Binding IconEmoji}"
                                                   FontSize="16"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Style="{StaticResource ProductivityBody}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- Typing indicator dots shown while the AI is streaming -->
            <CollectionView.Footer>
                <HorizontalStackLayout x:Name="TypingIndicator"
                                       IsVisible="{Binding IsStreaming}"
                                       Spacing="5"
                                       Margin="20,4,0,14">
                    <BoxView x:Name="Dot1" WidthRequest="6" HeightRequest="6"
                             CornerRadius="3"
                             Color="{DynamicResource ProductivityFocus}"
                             Opacity="0.4"/>
                    <BoxView x:Name="Dot2" WidthRequest="6" HeightRequest="6"
                             CornerRadius="3"
                             Color="{DynamicResource ProductivityFocus}"
                             Opacity="0.4"/>
                    <BoxView x:Name="Dot3" WidthRequest="6" HeightRequest="6"
                             CornerRadius="3"
                             Color="{DynamicResource ProductivityFocus}"
                             Opacity="0.4"/>
                </HorizontalStackLayout>
            </CollectionView.Footer>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:ChatMessageViewModel">
                    <Grid Padding="16,0,16,12">

                        <!-- User bubble — right aligned -->
                        <Border IsVisible="{Binding IsUser}"
                                HorizontalOptions="End"
                                MaximumWidthRequest="280"
                                Padding="14,10"
                                BackgroundColor="{DynamicResource ProductivityFocus}"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18,18,4,18"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Content}"
                                   TextColor="{DynamicResource ProductivityCtaText}"
                                   FontSize="14"
                                   LineBreakMode="WordWrap"/>
                        </Border>

                        <!-- Assistant bubble — left aligned, with optional action buttons -->
                        <VerticalStackLayout IsVisible="{Binding IsAssistant}"
                                             HorizontalOptions="Start"
                                             MaximumWidthRequest="300"
                                             Spacing="8">
                            <Border Padding="14,10"
                                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                                    Stroke="{DynamicResource ProductivityCardStroke}"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4,18,18,18"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Content}"
                                       Style="{StaticResource ProductivityBody}"
                                       LineBreakMode="WordWrap"/>
                            </Border>

                            <!-- Action pill buttons: BindableLayout avoids a nested CollectionView -->
                            <HorizontalStackLayout Spacing="8"
                                                   IsVisible="{Binding HasActions}"
                                                   BindableLayout.ItemsSource="{Binding Actions}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="chatModels:ChatAction">
                                        <Border Padding="12,7"
                                                BackgroundColor="Transparent"
                                                Stroke="{DynamicResource ProductivityFocus}"
                                                StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusPill}"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnActionTapped"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding Label}"
                                                   TextColor="{DynamicResource ProductivityFocus}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Error bubble — shown when IsError=true (Gemini quota, rate limit, etc.) -->
                        <Border IsVisible="{Binding IsError}"
                                HorizontalOptions="Start"
                                MaximumWidthRequest="300"
                                Padding="14,10"
                                BackgroundColor="#1A2020"
                                Stroke="#FF6B6B"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4,18,18,18"/>
                            </Border.StrokeShape>
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Start">
                                <Label Text="⚠"
                                       TextColor="#FF6B6B"
                                       FontSize="14"
                                       VerticalOptions="Start"/>
                                <Label Text="{Binding Content}"
                                       TextColor="#FF9B9B"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Start"/>
                            </HorizontalStackLayout>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Input area ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{DynamicResource ProductivityCardBackground}"
                StrokeThickness="0"
                Padding="16,12,16,32">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border Grid.Column="0"
                        BackgroundColor="{DynamicResource ProductivityCardBackgroundElevated}"
                        Stroke="{DynamicResource ProductivityCardStroke}"
                        StrokeThickness="1"
                        Padding="14,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                    </Border.StrokeShape>
                    <Entry x:Name="MessageEditor"
                           Text="{Binding InputText, Mode=TwoWay}"
                           TextChanged="OnMessageEditorTextChanged"
                           Completed="OnMessageEditorCompleted"
                           Placeholder="Ask your coach anything..."
                           PlaceholderColor="{DynamicResource ProductivityTextMuted}"
                           TextColor="{DynamicResource ProductivityTextPrimary}"
                           BackgroundColor="Transparent"
                           FontSize="14"
                           ReturnType="Send"
                           VerticalOptions="Center"
                           />
                </Border>

                <Border Grid.Column="1"
                        WidthRequest="44" HeightRequest="44"
                        BackgroundColor="{DynamicResource ProductivityFocus}"
                        StrokeThickness="0"
                        VerticalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SendCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="↑"
                           TextColor="{DynamicResource ProductivityCtaText}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>


        <!-- ── History overlay ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsVisible="{Binding ShowHistory}"
              BackgroundColor="{DynamicResource ProductivityPageBackground}"
              RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,24,20,12">
                <Button Grid.Column="0"
                        Text="✕"
                        Style="{StaticResource ProductivitySecondaryButton}"
                        Clicked="OnHistoryCloseClicked"
                        WidthRequest="34" HeightRequest="34"
                        Padding="0"
                        VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="Conversations"
                       Style="{StaticResource ProductivityHeadline}"
                       Margin="12,0,0,0"
                       VerticalOptions="Center"/>
                <Button Grid.Column="2"
                        Text="+ New"
                        Style="{StaticResource ProductivitySecondaryButton}"
                        Clicked="OnNewConversationClicked"
                        Padding="14,0"
                        HeightRequest="34"
                        VerticalOptions="Center"/>
            </Grid>

            <!-- Conversation list -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Conversations}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No conversations yet"
                           Style="{StaticResource ProductivityCaption}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,40"/>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ConversationViewModel">
                        <Border Margin="16,0,16,8"
                                Padding="16,14"
                                BackgroundColor="{DynamicResource ProductivityCardBackground}"
                                Stroke="{DynamicResource ProductivityCardStroke}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnConversationTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="3">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       Style="{StaticResource ProductivityBody}"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"/>
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding LastMessageAtDisplay}"
                                       Style="{StaticResource ProductivityCaption}"
                                       LineBreakMode="NoWrap"/>
                                <Label Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                       Text="›"
                                       Style="{StaticResource ProductivityCaption}"
                                       VerticalOptions="Center"
                                       Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>
</ContentPage>
