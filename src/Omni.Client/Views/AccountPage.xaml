<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Omni.Client.Presentation.ViewModels"
             x:Class="Omni.Client.AccountPage"
             x:DataType="vm:AccountViewModel"
             Shell.NavBarIsVisible="False"
             Background="{DynamicResource ProductivityPageGradient}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20,24,20,40">

            <!-- Header -->
            <Label Text="Account"
                   Style="{StaticResource ProductivityHeadline}"
                   Margin="0,0,0,4"/>
            <Label Text="Profile and preferences"
                   Style="{StaticResource ProductivityCaption}"
                   Margin="0,0,0,28"/>

            <!-- Profile Card -->
            <Border Margin="0,0,0,24" Padding="20"
                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                    Stroke="{DynamicResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            WidthRequest="52" HeightRequest="52"
                            BackgroundColor="{DynamicResource ProductivityFocusDim}"
                            Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26"/>
                        </Border.StrokeShape>
                        <Label x:Name="AvatarInitialsLabel"
                               Text="{Binding AvatarInitial}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource ProductivityFocus}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <!-- Email + Status -->
                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <ActivityIndicator x:Name="LoadingIndicator"
                                           IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           Color="{DynamicResource ProductivityFocus}"
                                           HeightRequest="18" WidthRequest="18"
                                           HorizontalOptions="Start"/>
                        <Label x:Name="EmailLabel" Text="{Binding Email}"
                               Style="{StaticResource ProductivityBody}"
                               IsVisible="{Binding IsNotLoading}"/>
                        <Label Text="Active account"
                               Style="{StaticResource ProductivityCaption}"/>
                    </VerticalStackLayout>
                    <!-- Sign Out -->
                    <Button Grid.Column="2"
                            x:Name="SignOutButton"
                            Text="Sign out"
                            Style="{StaticResource ProductivityDangerButton}"
                            VerticalOptions="Center"
                            IsEnabled="{Binding IsNotLoading}"
                            Clicked="OnSignOutClicked"/>
                </Grid>
            </Border>

            <!-- ── APPEARANCE ──────────────────────────────────────────── -->
            <Label Text="APPEARANCE"
                   Style="{StaticResource ProductivityUILabel}"
                   Margin="4,0,0,10"/>
            <Border Margin="0,0,0,24" Padding="16,16"
                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                    Stroke="{DynamicResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="App theme" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Choose light, dark, or follow your system" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                    </Grid>
                    <!-- Segmented theme picker -->
                    <Border BackgroundColor="{DynamicResource ProductivityCardBackgroundElevated}"
                            Stroke="{DynamicResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="3">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusPill}"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="3">
                            <Button x:Name="ThemeDarkBtn"
                                    Text="☽  Dark"
                                    Style="{StaticResource ProductivityPillButton}"
                                    HeightRequest="38"
                                    FontSize="13"
                                    Clicked="OnThemeDarkClicked"/>
                            <Button Grid.Column="1" x:Name="ThemeSystemBtn"
                                    Text="◐  System"
                                    Style="{StaticResource ProductivitySegmentButton}"
                                    HeightRequest="38"
                                    FontSize="13"
                                    Clicked="OnThemeSystemClicked"/>
                            <Button Grid.Column="2" x:Name="ThemeLightBtn"
                                    Text="☀  Light"
                                    Style="{StaticResource ProductivitySegmentButton}"
                                    HeightRequest="38"
                                    FontSize="13"
                                    Clicked="OnThemeLightClicked"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ── PRODUCTIVITY ─────────────────────────────────────────── -->
            <Label Text="PRODUCTIVITY"
                   Style="{StaticResource ProductivityUILabel}"
                   Margin="4,0,0,10"/>
            <Border Margin="0,0,0,24" Padding="0"
                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                    Stroke="{DynamicResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <!-- Daily Goal -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Daily focus goal" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Target focus minutes per day" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Picker Grid.Column="1" x:Name="DailyGoalPicker"
                                Title="Goal"
                                TextColor="{DynamicResource ProductivityTextPrimary}"
                                BackgroundColor="Transparent"
                                WidthRequest="96"
                                VerticalOptions="Center"
                                SelectedIndexChanged="OnDailyGoalChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{DynamicResource ProductivityCardStroke}" Margin="16,0"/>

                    <!-- Notification Intensity -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Notification intensity" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="How often to nudge during focus" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Picker Grid.Column="1" x:Name="NotificationIntensityPicker"
                                Title="Level"
                                TextColor="{DynamicResource ProductivityTextPrimary}"
                                BackgroundColor="Transparent"
                                WidthRequest="110"
                                VerticalOptions="Center"
                                SelectedIndexChanged="OnNotificationIntensityChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{DynamicResource ProductivityCardStroke}" Margin="16,0"/>

                    <!-- Show Streak -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Show streak on Home" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Display daily streak count badge" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="StreakVisibleSwitch"
                                IsToggled="{Binding StreakVisible}"
                                OnColor="{DynamicResource ProductivityFocus}"
                                VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{DynamicResource ProductivityCardStroke}" Margin="16,0"/>

                    <!-- Focus Hours (coming soon) -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Focus hours window" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="Quiet hours window, e.g. 09:00–18:00" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="Soon"
                               Style="{StaticResource ProductivityCaption}"
                               VerticalOptions="Center"
                               Margin="0,0,4,0"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── INTEGRATIONS ─────────────────────────────────────────── -->
            <Label Text="INTEGRATIONS"
                   Style="{StaticResource ProductivityUILabel}"
                   Margin="4,0,0,10"/>
            <Border Margin="0,0,0,24" Padding="0"
                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                    Stroke="{DynamicResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#1A2A4A"
                                Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Text="📅" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Google Calendar" Style="{StaticResource ProductivityBody}"/>
                            <Label x:Name="GCalStatusLabel"
                                   Text="Not connected"
                                   Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="2"
                                x:Name="GCalConnectButton"
                                Text="Connect"
                                Style="{StaticResource ProductivityPillButton}"
                                FontSize="12"
                                HeightRequest="34"
                                VerticalOptions="Center"
                                Clicked="OnGCalConnectClicked"/>
                    </Grid>
                    <BoxView x:Name="GCalSyncDivider"
                             HeightRequest="1" Color="{DynamicResource ProductivityCardStroke}"
                             Margin="16,0" IsVisible="False"/>
                    <Grid x:Name="GCalSyncRow"
                          ColumnDefinitions="*,Auto" Padding="16,14"
                          IsVisible="False">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Sync now" Style="{StaticResource ProductivityBody}"/>
                            <Label x:Name="GCalLastSyncLabel"
                                   Text="Never synced"
                                   Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                x:Name="GCalSyncButton"
                                Text="↻ Sync"
                                Style="{StaticResource ProductivitySecondaryButton}"
                                FontSize="12"
                                HeightRequest="34"
                                VerticalOptions="Center"
                                Clicked="OnGCalSyncClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── SECURITY ─────────────────────────────────────────────── -->
            <Label Text="SECURITY"
                   Style="{StaticResource ProductivityUILabel}"
                   Margin="4,0,0,10"/>
            <Border Margin="0,0,0,32" Padding="0"
                    BackgroundColor="{DynamicResource ProductivityCardBackground}"
                    Stroke="{DynamicResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="Change password"
                               Style="{StaticResource ProductivityBody}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Soon"
                               Style="{StaticResource ProductivityCaption}"
                               VerticalOptions="Center"
                               Margin="0,0,4,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{DynamicResource ProductivityCardStroke}" Margin="16,0"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="Delete account"
                               Style="{StaticResource ProductivityBody}"
                               TextColor="{DynamicResource ProductivityDanger}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Soon"
                               Style="{StaticResource ProductivityCaption}"
                               VerticalOptions="Center"
                               Margin="0,0,4,0"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Version -->
            <Label Text="Omni · v1.0"
                   Style="{StaticResource ProductivityCaption}"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
