<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.CalendarPage"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <StaticResource Key="ProductivityPageGradient"/>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Padding="20,24,20,0" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
            <Button Grid.Column="0"
                    x:Name="PrevButton"
                    Text="‹"
                    FontSize="22"
                    Style="{StaticResource ProductivitySecondaryButton}"
                    WidthRequest="40" HeightRequest="40" Padding="0"
                    Clicked="OnPrevClicked"/>
            <Label Grid.Column="1"
                   x:Name="MonthYearLabel"
                   Text="March 2026"
                   Style="{StaticResource ProductivityHeadline}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Text="›"
                    FontSize="22"
                    Style="{StaticResource ProductivitySecondaryButton}"
                    WidthRequest="40" HeightRequest="40" Padding="0"
                    Clicked="OnNextClicked"/>
            <Button Grid.Column="3"
                    x:Name="TodayButton"
                    Text="Today"
                    FontSize="13"
                    Style="{StaticResource ProductivityPillButton}"
                    HeightRequest="36"
                    Clicked="OnTodayClicked"/>
        </Grid>

        <!-- ── View selector + Sync status row ── -->
        <Grid Grid.Row="1" Padding="20,12,20,4" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <!-- Month / Week / Day toggle -->
            <Border Grid.Column="0"
                    Padding="2"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="2">
                    <Button x:Name="MonthViewBtn"
                            Grid.Column="0"
                            Text="Month"
                            FontSize="13"
                            Style="{StaticResource ProductivityPillButton}"
                            HeightRequest="32"
                            Clicked="OnMonthViewClicked"/>
                    <Button x:Name="WeekViewBtn"
                            Grid.Column="1"
                            Text="Week"
                            FontSize="13"
                            Style="{StaticResource ProductivitySecondaryButton}"
                            HeightRequest="32"
                            Clicked="OnWeekViewClicked"/>
                    <Button x:Name="DayViewBtn"
                            Grid.Column="2"
                            Text="Day"
                            FontSize="13"
                            Style="{StaticResource ProductivitySecondaryButton}"
                            HeightRequest="32"
                            Clicked="OnDayViewClicked"/>
                </Grid>
            </Border>

            <!-- Sync status pill -->
            <Border Grid.Column="1"
                    Padding="8,4"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSyncStatusTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                    <Label x:Name="SyncDotLabel" Text="●" FontSize="10"
                           TextColor="#44444F" VerticalOptions="Center"/>
                    <Label x:Name="SyncTextLabel" Text="Sync"
                           FontSize="11" TextColor="#66667A" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ── Day-of-week header (Month view only) ── -->
        <Grid x:Name="WeekdayHeader" Grid.Row="2"
              ColumnDefinitions="*,*,*,*,*,*,*"
              Padding="12,0,12,6">
            <Label Grid.Column="0" Text="Sun" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="1" Text="Mon" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="2" Text="Tue" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="3" Text="Wed" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="4" Text="Thu" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="5" Text="Fri" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
            <Label Grid.Column="6" Text="Sat" FontSize="11" TextColor="#66667A" HorizontalOptions="Center"/>
        </Grid>

        <!-- ── Calendar body ── -->
        <Grid Grid.Row="3">

            <!-- ════ MONTH VIEW ════ -->
            <Grid x:Name="MonthView" RowDefinitions="*" Padding="10,0,10,0">
                <ScrollView VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout x:Name="MonthGridContainer" Spacing="3"/>
                </ScrollView>
            </Grid>

            <!-- ════ WEEK VIEW ════ -->
            <Grid x:Name="WeekView" IsVisible="False" RowDefinitions="Auto,Auto,*" Padding="0">

                <!-- Day headers row -->
                <Grid x:Name="WeekDayHeaders" Grid.Row="0"
                      ColumnDefinitions="44,*,*,*,*,*,*,*"
                      Padding="0,4,0,4"
                      BackgroundColor="{StaticResource ProductivityPageBackground}"/>

                <!-- All-day events strip -->
                <Grid x:Name="WeekAllDayStrip" Grid.Row="1"
                      ColumnDefinitions="44,*,*,*,*,*,*,*"
                      MinimumHeightRequest="0"
                      BackgroundColor="{StaticResource ProductivityCardBackground}"
                      Padding="0,4,0,4"/>

                <ScrollView Grid.Row="2" x:Name="WeekScrollView">
                    <Grid x:Name="WeekTimeGrid" ColumnDefinitions="44,*,*,*,*,*,*,*" RowSpacing="0"/>
                </ScrollView>
            </Grid>

            <!-- ════ DAY VIEW ════ -->
            <Grid x:Name="DayView" IsVisible="False" RowDefinitions="Auto,Auto,*" Padding="0">

                <!-- Day label -->
                <Label x:Name="DayViewTitle" Grid.Row="0"
                       Text="Saturday, 21 March"
                       Style="{StaticResource ProductivityBody}"
                       FontAttributes="Bold"
                       Margin="20,8,20,4"/>

                <!-- All-day events strip -->
                <VerticalStackLayout x:Name="DayAllDayStrip" Grid.Row="1"
                                     Padding="20,4,20,4" Spacing="3"
                                     BackgroundColor="{StaticResource ProductivityCardBackground}"
                                     MinimumHeightRequest="0"/>

                <ScrollView Grid.Row="2" x:Name="DayScrollView">
                    <Grid x:Name="DayTimeGrid" ColumnDefinitions="52,*" RowSpacing="0"/>
                </ScrollView>
            </Grid>

        </Grid>

        <!-- ── FAB: New Event ── -->
        <Border Grid.RowSpan="4"
                WidthRequest="56" HeightRequest="56"
                BackgroundColor="{StaticResource ProductivityFocus}"
                Stroke="Transparent"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,24,32">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="{StaticResource ProductivityFocus}" Offset="0,4" Radius="12" Opacity="0.4"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFabTapped"/>
            </Border.GestureRecognizers>
            <Label Text="+" FontSize="28" FontAttributes="Bold"
                   TextColor="#0F1210"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   Margin="0,-2,0,0"/>
        </Border>

        <!-- ── Day detail bottom sheet (month view tap) ── -->
        <Grid x:Name="DayDetailOverlay" Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </Grid.GestureRecognizers>
            <Border x:Name="DayDetailSheet"
                    VerticalOptions="End"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,0,0"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="20,16,20,36" Spacing="12">
                    <BoxView WidthRequest="36" HeightRequest="4" CornerRadius="2"
                             Color="#44444F" HorizontalOptions="Center"/>
                    <Label x:Name="DayDetailTitle"
                           Text="Monday, 24 March"
                           Style="{StaticResource ProductivityBody}"
                           FontAttributes="Bold"/>
                    <ScrollView MaximumHeightRequest="320">
                        <VerticalStackLayout x:Name="DayDetailList" Spacing="8"/>
                    </ScrollView>
                    <Button Text="+ Add event for this day"
                            Style="{StaticResource ProductivityPillButton}"
                            Clicked="OnAddTaskForDayClicked"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Event creation bottom sheet ── -->
        <Grid x:Name="CreateEventOverlay" Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCreateEventOverlayTapped"/>
            </Grid.GestureRecognizers>
            <Border x:Name="CreateEventSheet"
                    VerticalOptions="End"
                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,0,0"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="20,16,20,36" Spacing="14">
                    <!-- Handle -->
                    <BoxView WidthRequest="36" HeightRequest="4" CornerRadius="2"
                             Color="#44444F" HorizontalOptions="Center"/>
                    <!-- Title -->
                    <Label Text="New Event" Style="{StaticResource ProductivityTitle}"/>

                    <!-- Event title input -->
                    <Border Padding="12,0"
                            BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" HeightRequest="48">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Entry x:Name="EventTitleEntry"
                               Placeholder="Event title"
                               PlaceholderColor="#44444F"
                               TextColor="{StaticResource ProductivityTextPrimary}"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Date picker row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Padding="12,0"
                                BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                                Stroke="{StaticResource ProductivityCardStroke}"
                                StrokeThickness="1" HeightRequest="48">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <DatePicker x:Name="EventDatePicker"
                                        TextColor="{StaticResource ProductivityTextPrimary}"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center"/>
                        </Border>
                        <!-- All-day toggle -->
                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="All day"
                                   Style="{StaticResource ProductivityBody}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1" x:Name="AllDaySwitch"
                                    OnColor="{StaticResource ProductivityFocus}"
                                    VerticalOptions="Center"
                                    Toggled="OnAllDayToggled"/>
                        </Grid>
                    </Grid>

                    <!-- Time pickers (hidden when all-day) -->
                    <Grid x:Name="TimePickerRow" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Padding="12,0"
                                BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                                Stroke="{StaticResource ProductivityCardStroke}"
                                StrokeThickness="1" HeightRequest="48">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <TimePicker x:Name="EventStartTime"
                                        TextColor="{StaticResource ProductivityTextPrimary}"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1" Padding="12,0"
                                BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                                Stroke="{StaticResource ProductivityCardStroke}"
                                StrokeThickness="1" HeightRequest="48">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <TimePicker x:Name="EventEndTime"
                                        TextColor="{StaticResource ProductivityTextPrimary}"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Calendar type picker -->
                    <Border Padding="12,0"
                            BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" HeightRequest="48">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Picker x:Name="CalendarTypePicker"
                                Title="Save to..."
                                TitleColor="#44444F"
                                TextColor="{StaticResource ProductivityTextPrimary}"
                                BackgroundColor="Transparent"
                                VerticalOptions="Center"/>
                    </Border>

                    <!-- Notes -->
                    <Border Padding="12,8"
                            BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Editor x:Name="EventNotesEditor"
                                Placeholder="Notes (optional)"
                                PlaceholderColor="#44444F"
                                TextColor="{StaticResource ProductivityTextPrimary}"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="48"
                                MaximumHeightRequest="96"/>
                    </Border>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Cancel"
                                Style="{StaticResource ProductivitySecondaryButton}"
                                Clicked="OnCreateEventCancel"/>
                        <Button Grid.Column="1" Text="Save Event"
                                Style="{StaticResource ProductivityCtaButton}"
                                Clicked="OnCreateEventSave"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
