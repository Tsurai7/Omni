<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Omni.Client.Controls"
             xmlns:usageModels="clr-namespace:Omni.Client.Models.Usage"
             xmlns:vm="clr-namespace:Omni.Client.Presentation.ViewModels"
             x:Class="Omni.Client.UsageStatsPage"
             x:DataType="vm:UsageStatsViewModel"
             Title="Stats"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <StaticResource Key="ProductivityPageGradient"/>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- ═══ Header ═══════════════════════════════════════════════════════ -->
        <VerticalStackLayout Grid.Row="0" Padding="20,24,20,12" Spacing="3">
            <Label Text="Stats" Style="{StaticResource ProductivityHeadline}"/>
            <Label Text="Your productivity patterns" Style="{StaticResource ProductivityCaption}"/>
        </VerticalStackLayout>

        <!-- Network error banner -->
        <controls:NetworkErrorBanner x:Name="StatsNetworkBanner" Grid.Row="1"/>

        <!-- ═══ Period Selector ══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="20,0,20,12"
                BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                Stroke="{StaticResource ProductivityCardStroke}"
                StrokeThickness="1" Padding="4">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusXl}"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                <Button x:Name="PeriodTodayBtn" Text="Today"
                        Style="{StaticResource ProductivityPillButton}"
                        Clicked="OnPeriodTodayClicked"/>
                <Button Grid.Column="1" x:Name="PeriodWeekBtn" Text="Week"
                        Style="{StaticResource ProductivitySegmentButton}"
                        Clicked="OnPeriodWeekClicked"/>
                <Button Grid.Column="2" x:Name="PeriodMonthBtn" Text="Month"
                        Style="{StaticResource ProductivitySegmentButton}"
                        Clicked="OnPeriodMonthClicked"/>
            </Grid>
        </Border>

        <!-- ═══ Summary Metrics Row ══════════════════════════════════════════ -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="20,0,20,12">
            <controls:StatCard Value="{Binding TotalFocusTime}"
                               Caption="Focus time"
                               AccentColor="{StaticResource ProductivityFocus}"/>
            <controls:StatCard Grid.Column="1"
                               Value="{Binding SummaryAvgScore}"
                               Caption="Avg score"
                               AccentColor="{StaticResource ProductivityNeutral}"/>
            <controls:StatCard Grid.Column="2"
                               Value="{Binding SummaryPeakHour}"
                               Caption="Peak hour"
                               AccentColor="{StaticResource ProductivityAmber}"/>
        </Grid>

        <!-- ═══ Scrollable content ═══════════════════════════════════════════ -->
        <RefreshView x:Name="RefreshView" Grid.Row="4"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- AI Insight / Recommendation -->
                    <Border x:Name="InsightsFrame" Margin="20,0,20,12"
                            IsVisible="{Binding HasInsights}"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityFocusDim}"
                            StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="INSIGHTS" Style="{StaticResource ProductivityUILabel}"/>
                            <Label Text="{Binding InsightBiggestDistraction}" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="{Binding InsightFocusThisWeek}" Style="{StaticResource ProductivityBody}"/>
                            <Label Text="{Binding InsightTrend}"
                                   Style="{StaticResource ProductivityBodySecondary}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Recommendation chip -->
                    <Border Margin="20,0,20,12" IsVisible="{Binding HasRecommendation}"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="Try:" Style="{StaticResource ProductivityCaption}" VerticalOptions="Center"/>
                            <Button Text="{Binding RecommendationChipText}"
                                    Style="{StaticResource ProductivityPillButton}"
                                    Command="{Binding RecommendationChipCommand}"
                                    VerticalOptions="Center"/>

                        </HorizontalStackLayout>
                    </Border>

                    <!-- Charts: Pie + Bar side-by-side -->
                    <Border x:Name="ChartsFrame" Margin="20,0,20,12"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Usage breakdown" Style="{StaticResource ProductivityTitle}"/>
                            <GraphicsView x:Name="PieChartView" HeightRequest="220" HorizontalOptions="Fill"/>
                            <GraphicsView x:Name="BarChartView" HeightRequest="220" HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Focus Score Trend Chart -->
                    <Border Margin="20,0,20,12"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Focus score trend" Style="{StaticResource ProductivityTitle}"/>
                            <GraphicsView x:Name="TrendChartView" HeightRequest="140" HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Activity Heatmap -->
                    <Border Margin="20,0,20,12"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Activity heatmap" Style="{StaticResource ProductivityTitle}"/>
                            <Label Text="13 weeks of daily focus" Style="{StaticResource ProductivityCaption}"/>
                            <GraphicsView x:Name="HeatmapView" HeightRequest="140" HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Filters -->
                    <Border Margin="20,0,20,12"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1" Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Category" Style="{StaticResource ProductivityCaption}"/>
                                <Border BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                                        Stroke="{StaticResource ProductivityCardStroke}"
                                        StrokeThickness="1" Padding="4,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusXs}"/>
                                    </Border.StrokeShape>
                                    <Picker x:Name="CategoryPicker" Title="All categories"
                                            TextColor="{StaticResource ProductivityTextPrimary}"
                                            BackgroundColor="Transparent"
                                            HeightRequest="38"
                                            SelectedIndexChanged="OnCategoryChanged"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="App" Style="{StaticResource ProductivityCaption}"/>
                                <Border BackgroundColor="{StaticResource ProductivityCardBackgroundElevated}"
                                        Stroke="{StaticResource ProductivityCardStroke}"
                                        StrokeThickness="1" Padding="4,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusXs}"/>
                                    </Border.StrokeShape>
                                    <Picker x:Name="AppPicker" Title="All apps"
                                            TextColor="{StaticResource ProductivityTextPrimary}"
                                            BackgroundColor="Transparent"
                                            HeightRequest="38"
                                            SelectedIndexChanged="OnAppFilterChanged"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Usage list -->
                    <CollectionView x:Name="UsageList"
                                    ItemsSource="{Binding GroupedEntries}"
                                    IsGrouped="True"
                                    EmptyView="{Binding EmptyView}"
                                    Margin="20,0">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="usageModels:UsageDateGroup">
                                <Grid Padding="0,12,0,6" BackgroundColor="Transparent">
                                    <HorizontalStackLayout Spacing="10">
                                        <BoxView Color="{StaticResource ProductivityFocus}"
                                                 WidthRequest="3" HeightRequest="14"
                                                 CornerRadius="2" VerticalOptions="Center"/>
                                        <Label Text="{Binding Date}" Style="{StaticResource ProductivityBodyBold}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="usageModels:UsageStatsItem">
                                <Border Padding="14,12" Margin="0,0,0,8"
                                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                                        Stroke="{StaticResource ProductivityCardStroke}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusSm}"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding AppName}" Style="{StaticResource ProductivityBody}"/>
                                            <Label Text="{Binding Category}" Style="{StaticResource ProductivityCaption}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding FormattedTime}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource ProductivityFocus}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Bottom padding -->
                    <BoxView HeightRequest="24" Color="Transparent"/>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
