<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Omni.Client.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Omni.Client"
    xmlns:controls="clr-namespace:Omni.Client.Controls"
    Shell.FlyoutBehavior="Locked"
    Shell.FlyoutHeaderBehavior="Fixed"
    Shell.FlyoutWidth="220"
    Shell.FlyoutBackgroundColor="{DynamicResource SidebarBackground}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource ProductivityPageBackground}">

    <!-- ── Sidebar header: logo mark + wordmark ── -->
    <Shell.FlyoutHeader>
        <controls:SidebarHeader/>
    </Shell.FlyoutHeader>

    <!-- ── Sidebar footer: avatar + email ── -->
    <Shell.FlyoutFooter>
        <controls:SidebarFooter/>
    </Shell.FlyoutFooter>

    <!-- ── Nav item row template ── -->
    <Shell.ItemTemplate>
        <DataTemplate x:DataType="BaseShellItem">
            <Border Margin="8,2,8,2"
                    HeightRequest="44"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsChecked}" Value="True">
                        <Setter Property="BackgroundColor"
                                Value="{DynamicResource SidebarItemActiveBg}"/>
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="18,10,*" Padding="12,0" VerticalOptions="Center">

                    <Image Grid.Column="0"
                           Source="{Binding FlyoutIcon}"
                           WidthRequest="18" HeightRequest="18"
                           VerticalOptions="Center"
                           Aspect="AspectFit"/>

                    <Label Grid.Column="2"
                           Text="{Binding Title}"
                           FontFamily="InterMedium"
                           FontSize="13.5"
                           TextColor="{DynamicResource ProductivityTextSecondary}"
                           VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsChecked}" Value="True">
                                <Setter Property="TextColor"
                                        Value="{DynamicResource ProductivityUIAccent}"/>
                                <Setter Property="FontFamily" Value="InterSemiBold"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                </Grid>
            </Border>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- ── MenuItem (divider) template ── -->
    <Shell.MenuItemTemplate>
        <DataTemplate>
            <BoxView HeightRequest="1"
                     Margin="16,6,16,6"
                     BackgroundColor="{DynamicResource ProductivityCardStroke}"/>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <!-- ════════════════════════════════
         PRIMARY NAVIGATION
         ════════════════════════════════ -->

    <FlyoutItem Title="Home" Icon="tab_home.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Stats" Icon="tab_stats.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:UsageStatsPage}"
            Route="UsageStatsPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Coach" Icon="tab_coach.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:ChatPage}"
            Route="ChatPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Session" Icon="tab_session.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:SessionPage}"
            Route="SessionPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Tasks" Icon="tab_tasks.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:TasksPage}"
            Route="TasksPage"/>
    </FlyoutItem>

    <!-- Visual divider between primary and secondary groups -->
    <MenuItem/>

    <!-- ════════════════════════════════
         SECONDARY NAVIGATION
         ════════════════════════════════ -->

    <FlyoutItem Title="Calendar" Icon="tab_calendar.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:CalendarPage}"
            Route="CalendarPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Account" Icon="tab_account.png">
        <ShellContent
            ContentTemplate="{DataTemplate local:AccountPage}"
            Route="AccountPage"/>
    </FlyoutItem>

</Shell>
