<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Omni.Client.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Omni.Client"
    Shell.FlyoutBehavior="Flyout"
    Title="Omni.Client">

    <FlyoutItem Title="Home" Icon="dotnet_bot.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>
    <FlyoutItem Title="Usage stats" Icon="dotnet_bot.png">
        <ShellContent
            Title="Usage stats"
            ContentTemplate="{DataTemplate local:UsageStatsPage}"
            Route="UsageStatsPage" />
    </FlyoutItem>
    <FlyoutItem Title="Session" Icon="dotnet_bot.png">
        <ShellContent
            Title="Session"
            ContentTemplate="{DataTemplate local:SessionPage}"
            Route="SessionPage" />
    </FlyoutItem>
    <FlyoutItem Title="Tasks" Icon="dotnet_bot.png">
        <ShellContent
            Title="Tasks"
            ContentTemplate="{DataTemplate local:TasksPage}"
            Route="TasksPage" />
    </FlyoutItem>
    <FlyoutItem Title="Account" Icon="dotnet_bot.png">
        <ShellContent
            Title="Account"
            ContentTemplate="{DataTemplate local:AccountPage}"
            Route="AccountPage" />
    </FlyoutItem>
</Shell>
