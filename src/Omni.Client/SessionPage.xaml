<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.SessionPage"
             Title="Session"
             BackgroundColor="#0F0F0F">
    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" CornerRadius="15" Margin="20" BackgroundColor="#1E1E1E" BorderColor="#2D2D2D" Padding="20" HasShadow="True">
            <VerticalStackLayout Spacing="12">
                <Label Text="Track activity" FontSize="24" TextColor="#E0E0E0" FontAttributes="Bold"/>
                <Label x:Name="TimerLabel" Text="00:00" FontSize="32" TextColor="#4ECCA3" FontAttributes="Bold" HorizontalOptions="Center"/>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Duration" FontSize="12" TextColor="#A0A0A0"/>
                    <Picker x:Name="DurationPicker" Title="Duration" TextColor="#E0E0E0" BackgroundColor="#2D2D2D" SelectedIndexChanged="OnDurationChanged"/>
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="CustomDurationSection" Spacing="6" IsVisible="False">
                    <Label Text="Custom (minutes)" FontSize="12" TextColor="#A0A0A0"/>
                    <Entry x:Name="CustomDurationEntry" Placeholder="e.g. 90" Keyboard="Numeric" TextColor="#E0E0E0" BackgroundColor="#2D2D2D" PlaceholderColor="#808080"/>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Activity name" FontSize="12" TextColor="#A0A0A0"/>
                    <Entry x:Name="ActivityNameEntry" Placeholder="e.g. Work, Focus, Break" TextColor="#E0E0E0" BackgroundColor="#2D2D2D" PlaceholderColor="#808080"/>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Type" FontSize="12" TextColor="#A0A0A0"/>
                    <Picker x:Name="ActivityTypePicker" Title="Type" TextColor="#E0E0E0" BackgroundColor="#2D2D2D" SelectedIndexChanged="OnActivityTypeChanged"/>
                </VerticalStackLayout>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="StartButton" Text="Start" BackgroundColor="#4ECCA3" TextColor="#0F0F0F" Clicked="OnStartClicked"/>
                    <Button x:Name="StopButton" Text="Stop" Grid.Column="1" BackgroundColor="#2D2D2D" TextColor="#E0E0E0" Clicked="OnStopClicked" IsEnabled="False"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>
        <RefreshView x:Name="RefreshView" Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">
                    <CollectionView x:Name="SessionList"
                                    ItemsSource="{Binding GroupedEntries}"
                                    IsGrouped="True"
                                    EmptyView="{Binding EmptyView}"
                                    Margin="20,0">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="20,12,20,6" BackgroundColor="#1E1E1E">
                                    <BoxView Color="#4ECCA3" HeightRequest="2" WidthRequest="40" VerticalOptions="Center"/>
                                    <Label Text="{Binding Date}" Margin="50,0,0,0" FontSize="16" TextColor="#E0E0E0" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="12" Padding="16" Margin="20,0,20,8" BackgroundColor="#1E1E1E" BorderColor="#2D2D2D">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}" FontSize="15" TextColor="#E0E0E0"/>
                                            <Label Text="{Binding ActivityType}" FontSize="12" TextColor="#A0A0A0"/>
                                            <Label Text="{Binding StartedAtDisplay}" FontSize="12" TextColor="#808080"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding DurationDisplay}" FontSize="14" TextColor="#4ECCA3" VerticalOptions="Center"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
