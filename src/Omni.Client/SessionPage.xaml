<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.SessionPage"
             Title="Session"
             BackgroundColor="{StaticResource ProductivityPageBackground}">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Margin="20" Padding="20"
                BackgroundColor="{StaticResource ProductivityCardBackground}"
                Stroke="{StaticResource ProductivityCardStroke}"
                StrokeThickness="1">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.25"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Track activity" Style="{StaticResource ProductivityHeadline}"/>
                <Label x:Name="TimerLabel" Text="00:00" Style="{StaticResource ProductivityDisplay}" HorizontalOptions="Center"/>
                <Label Text="Set your goal above and tap Start." Style="{StaticResource ProductivityCaption}" HorizontalOptions="Center"/>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Duration" Style="{StaticResource ProductivityCaption}"/>
                    <Picker x:Name="DurationPicker" Title="Duration" TextColor="{StaticResource ProductivityTextPrimary}" BackgroundColor="{StaticResource ProductivityCardStroke}" SelectedIndexChanged="OnDurationChanged"/>
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="CustomDurationSection" Spacing="6" IsVisible="False">
                    <Label Text="Custom (minutes)" Style="{StaticResource ProductivityCaption}"/>
                    <Entry x:Name="CustomDurationEntry" Placeholder="e.g. 90" Keyboard="Numeric" TextColor="{StaticResource ProductivityTextPrimary}" BackgroundColor="{StaticResource ProductivityCardStroke}" PlaceholderColor="{StaticResource ProductivityTextTertiary}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Activity name" Style="{StaticResource ProductivityCaption}"/>
                    <Entry x:Name="ActivityNameEntry" Placeholder="e.g. Work, Focus, Break" TextColor="{StaticResource ProductivityTextPrimary}" BackgroundColor="{StaticResource ProductivityCardStroke}" PlaceholderColor="{StaticResource ProductivityTextTertiary}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Type" Style="{StaticResource ProductivityCaption}"/>
                    <Picker x:Name="ActivityTypePicker" Title="Type" TextColor="{StaticResource ProductivityTextPrimary}" BackgroundColor="{StaticResource ProductivityCardStroke}" SelectedIndexChanged="OnActivityTypeChanged"/>
                </VerticalStackLayout>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="StartButton" Text="Start" Style="{StaticResource ProductivityCtaButton}" Clicked="OnStartClicked"/>
                    <Button x:Name="StopButton" Text="Stop" Grid.Column="1" Style="{StaticResource ProductivitySecondaryButton}" Clicked="OnStopClicked" IsEnabled="False"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
        <RefreshView x:Name="RefreshView" Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">
                    <CollectionView x:Name="SessionList"
                                    ItemsSource="{Binding GroupedEntries}"
                                    IsGrouped="True"
                                    EmptyView="{Binding EmptyView}"
                                    Margin="20,0">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="20,12,20,6" BackgroundColor="{StaticResource ProductivityCardBackground}">
                                    <BoxView Color="{StaticResource ProductivityFocus}" HeightRequest="2" WidthRequest="40" VerticalOptions="Center"/>
                                    <Label Text="{Binding Date}" Margin="50,0,0,0" Style="{StaticResource ProductivityTitle}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16" Margin="20,0,20,8" BackgroundColor="{StaticResource ProductivityCardBackground}" Stroke="{StaticResource ProductivityCardStroke}" StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}" Style="{StaticResource ProductivityBody}"/>
                                            <Label Text="{Binding ActivityType}" Style="{StaticResource ProductivityCaption}"/>
                                            <Label Text="{Binding StartedAtDisplay}" Style="{StaticResource ProductivityCaption}" TextColor="{StaticResource ProductivityTextTertiary}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding DurationDisplay}" FontSize="14" TextColor="{StaticResource ProductivityFocus}" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- Post-session score sheet overlay -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsPostSessionSheetVisible}"
              BackgroundColor="#80000000" Padding="24"
              VerticalOptions="Center" HorizontalOptions="Fill">
            <Border BackgroundColor="{StaticResource ProductivityCardBackground}"
                    Stroke="{StaticResource ProductivityCardStroke}"
                    StrokeThickness="1" Padding="24"
                    VerticalOptions="Center" HorizontalOptions="Center" MaximumWidthRequest="340">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Label Text="Session complete" Style="{StaticResource ProductivityHeadline}" HorizontalOptions="Center"/>
                    <Label Text="{Binding ScoreLabel}" FontSize="48" TextColor="{StaticResource ProductivityFocus}" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding ScoreSummaryLabel}" Style="{StaticResource ProductivityBody}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Label Text="How was your focus?" Style="{StaticResource ProductivityCaption}" HorizontalOptions="Center"/>
                    <Button Text="Done" Style="{StaticResource ProductivityCtaButton}" Clicked="OnPostSessionDoneClicked"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
