<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Omni.Client.MainPage"
             Title="Timely Tracker"
             BackgroundColor="#0F0F0F">
    <Frame CornerRadius="15"
           Margin="20"
           BackgroundColor="#1E1E1E"
           BorderColor="#2D2D2D"
           Padding="0"
           HasShadow="True">
    
    <RefreshView Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <Grid RowDefinitions="Auto,Auto,*" Padding="20,10">
                <!-- Header -->
                <VerticalStackLayout Grid.Row="0" Spacing="5">
                    <Label Text="Timely Tracker" 
                           FontSize="28"
                           TextColor="#E0E0E0"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    
                    <Label Text="Your activity statistics" 
                           FontSize="14"
                           TextColor="#A0A0A0"
                           HorizontalOptions="Center"/>
                    
                    <BoxView HeightRequest="1" 
                             Margin="0,15,0,10"
                             Color="#2D2D2D"/>
                </VerticalStackLayout>
                
                <!-- Stats Summary -->
                <Frame Grid.Row="1"
                       CornerRadius="15"
                       Padding="20,15"
                       Margin="0,0,0,20"
                       BackgroundColor="#1E1E1E"
                       BorderColor="#2D2D2D">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <Label Text="Total tracked time:" 
                               Grid.Column="0" Grid.Row="0"
                               TextColor="#A0A0A0"
                               FontSize="14"/>
                        
                        <Label Text="{Binding TotalTrackedTime}" 
                               Grid.Column="1" Grid.Row="0"
                               TextColor="#FFFFFF"
                               FontSize="14"
                               HorizontalOptions="End"/>
                        
                        <Label Text="Current category:" 
                               Grid.Column="0" Grid.Row="1"
                               TextColor="#A0A0A0"
                               FontSize="14"
                               Margin="0,10,0,0"/>
                        
                        <Label Text="{Binding CurrentCategory}" 
                               Grid.Column="1" Grid.Row="1"
                               TextColor="#4ECCA3"
                               FontSize="14"
                               HorizontalOptions="End"
                               Margin="0,10,0,0"/>
                    </Grid>
                </Frame>
                
                <!-- Apps List -->
                <CollectionView x:Name="AppUsageList" 
                              Grid.Row="2"
                              IsGrouped="True"
                              ItemsSource="{Binding GroupedApps}"
                              VerticalOptions="FillAndExpand">
                    
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="0,15,0,5" BackgroundColor="Transparent">
                                <BoxView Color="#4ECCA3" 
                                       HeightRequest="2"
                                       WidthRequest="40"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Center"/>
                                
                                <Label Text="{Binding Category}" 
                                       Margin="50,0,0,0"
                                       FontSize="16"
                                       TextColor="#FFFFFF"
                                       FontAttributes="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="12" 
                                   Padding="0"
                                   Margin="0,0,0,10"
                                   BackgroundColor="#1E1E1E"
                                   BorderColor="#2D2D2D"
                                   HasShadow="True">
                                <Grid Padding="15" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                                    <!-- Иконка приложения -->
                                    <Image Source="{Binding AppIcon}"
                                           WidthRequest="24" HeightRequest="24"
                                           VerticalOptions="Center"/>
                                    
                                    <!-- Название приложения -->
                                    <Label Text="{Binding AppName}" 
                                           Grid.Column="1"
                                           FontSize="16" TextColor="#FFFFFF"
                                           VerticalOptions="Center" Margin="10,0,0,0"/>
                                    
                                    <!-- Время работы -->
                                    <Label Text="{Binding FormattedTime}" 
                                           Grid.Column="2"
                                           TextColor="#4ECCA3" FontSize="14"
                                           HorizontalOptions="End" VerticalOptions="Center"/>
                                    
                                    <!-- Индикатор категории -->
                                    <BoxView Grid.Column="3" WidthRequest="4" HeightRequest="40"
                                             Color="{Binding CategoryColor}" CornerRadius="2"
                                             VerticalOptions="Center" Margin="10,0"/>
                                    
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="0,50">
                            <Image Source="empty_state.png"
                                   HeightRequest="120"
                                   Aspect="AspectFit"/>
                            
                            <Label Text="No active applications" 
                                   TextColor="#A0A0A0"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   Margin="0,20,0,0"/>
                        </StackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>
        </ScrollView>
    </RefreshView>
    </Frame>
</ContentPage>