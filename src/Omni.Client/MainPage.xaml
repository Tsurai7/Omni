<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Omni.Client.Controls"
             x:Class="Omni.Client.MainPage"
             Title="Timely Tracker"
             BackgroundColor="{StaticResource ProductivityPageBackground}">
    <RefreshView Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Padding="20,10">
                <!-- Header -->
                <VerticalStackLayout Grid.Row="0" Spacing="5">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Start">
                            <Label Text="Timely Tracker"
                                   Style="{StaticResource ProductivityHeadline}"/>
                            <Label Text="Your activity statistics"
                                   Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Sign out"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource ProductivityTextSecondary}"
                                FontSize="14"
                                VerticalOptions="Center"
                                Clicked="OnLogoutClicked"/>
                    </Grid>
                    <BoxView HeightRequest="1" Margin="0,15,0,10" Color="{StaticResource ProductivityCardStroke}"/>
                </VerticalStackLayout>

                <!-- Daily Pulse card -->
                <Border Grid.Row="1" Margin="0,0,0,16"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1"
                        Padding="20,16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.25"/>
                    </Border.Shadow>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Today" Style="{StaticResource ProductivityCaption}"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding GoalProgressLabel}" Style="{StaticResource ProductivityTitle}"/>
                                <ProgressBar Progress="{Binding GoalProgress}" ProgressColor="{StaticResource ProductivityFocus}" HeightRequest="6"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout HorizontalOptions="End" Spacing="2">
                                <Label Text="{Binding StreakDays, StringFormat='{0}'}" Style="{StaticResource ProductivityHeadline}"/>
                                <Label Text="day streak" Style="{StaticResource ProductivityCaption}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <Button Text="{Binding NextBestActionText}"
                                Style="{StaticResource ProductivityCtaButton}"
                                Command="{Binding NextBestActionCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Now (current activity state) -->
                <Border Grid.Row="2" Margin="0,0,0,16"
                        IsVisible="{Binding IsNowVisible}"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                    </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                        <BoxView x:Name="NowStateIndicator" WidthRequest="4" HeightRequest="40" VerticalOptions="Center"
                                 Color="{Binding NowStateColor}"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                            <Label Text="Now" Style="{StaticResource ProductivityCaption}"/>
                            <Label Text="{Binding NowAppName}" Style="{StaticResource ProductivityBodyBold}"/>
                            <Label Text="{Binding NowActivityState}" Style="{StaticResource ProductivityCaption}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Next best action row (single recommendation) -->
                <Border Grid.Row="3" Margin="0,0,0,16"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <Label Text="Next:" Style="{StaticResource ProductivityCaption}" VerticalOptions="Center"/>
                        <Label Text="{Binding NextBestActionText}" Style="{StaticResource ProductivityBody}" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                        <Button Text="Go" Style="{StaticResource ProductivitySecondaryButton}" Command="{Binding NextBestActionCommand}" VerticalOptions="Center" Padding="12,0"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Quick actions: surface main functions -->
                <Border Grid.Row="4" Margin="0,0,0,16"
                        BackgroundColor="{StaticResource ProductivityCardBackground}"
                        Stroke="{StaticResource ProductivityCardStroke}"
                        StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Quick actions" Style="{StaticResource ProductivityCaption}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Text="Start session" Style="{StaticResource ProductivitySecondaryButton}" Clicked="OnStartSessionClicked"/>
                            <Button Text="Add task" Grid.Column="1" Style="{StaticResource ProductivitySecondaryButton}" Clicked="OnAddTaskClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats + Apps List -->
                <VerticalStackLayout Grid.Row="5" Spacing="0">
                    <Border Margin="0,0,0,16"
                            BackgroundColor="{StaticResource ProductivityCardBackground}"
                            Stroke="{StaticResource ProductivityCardStroke}"
                            StrokeThickness="1"
                            Padding="20,15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusLg}"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <Label Text="Total tracked time:" Grid.Column="0" Grid.Row="0" Style="{StaticResource ProductivityCaption}"/>
                            <Label Text="{Binding TotalTrackedTime}" Grid.Column="1" Grid.Row="0" Style="{StaticResource ProductivityBody}" HorizontalOptions="End"/>
                            <Label Text="Current category:" Grid.Column="0" Grid.Row="1" Style="{StaticResource ProductivityCaption}" Margin="0,10,0,0"/>
                            <Label Text="{Binding CurrentCategory}" Grid.Column="1" Grid.Row="1" TextColor="{StaticResource ProductivityFocus}" FontSize="14" HorizontalOptions="End" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>

                    <CollectionView x:Name="AppUsageList"
                                    IsGrouped="True"
                                    ItemsSource="{Binding GroupedApps}"
                                    VerticalOptions="FillAndExpand">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="0,15,0,5" BackgroundColor="Transparent">
                                    <BoxView Color="{StaticResource ProductivityFocus}"
                                             HeightRequest="2" WidthRequest="40" HorizontalOptions="Start" VerticalOptions="Center"/>
                                    <Label Text="{Binding Category}" Margin="50,0,0,0" Style="{StaticResource ProductivityTitle}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="15" Margin="0,0,0,10"
                                    BackgroundColor="{StaticResource ProductivityCardBackground}"
                                    Stroke="{StaticResource ProductivityCardStroke}"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource ProductivityRadiusMd}"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="0">
                                        <Image Source="{Binding AppIcon}" WidthRequest="24" HeightRequest="24" VerticalOptions="Center"/>
                                        <Label Text="{Binding AppName}" Grid.Column="1" Style="{StaticResource ProductivityBody}" VerticalOptions="Center" Margin="10,0,0,0"/>
                                        <Label Text="{Binding FormattedTime}" Grid.Column="2" TextColor="{StaticResource ProductivityFocus}" FontSize="14" HorizontalOptions="End" VerticalOptions="Center"/>
                                        <BoxView Grid.Column="3" WidthRequest="4" HeightRequest="40" Color="{Binding CategoryColor}" VerticalOptions="Center" Margin="10,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="0,50">
                                <Image Source="dotnet_bot.png" HeightRequest="120" Aspect="AspectFit"/>
                                <Label Text="No active applications" Style="{StaticResource ProductivityCaption}" HorizontalOptions="Center" Margin="0,20,0,0"/>
                            </StackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </RefreshView>
</ContentPage>
