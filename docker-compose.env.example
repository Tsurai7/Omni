# Copy to .env in repo root (or set in shell). Do not commit .env.
# Postgres
POSTGRES_USER=omni
POSTGRES_PASSWORD=omni
POSTGRES_DB=omni
POSTGRES_PORT=5432

# Backend (required when running backend in Docker)
JWT_SECRET=your-secret-at-least-32-chars-long-change-in-production
JWT_EXPIRY_HOURS=24
BACKEND_PORT=8080

# Google Calendar integration (create OAuth 2.0 credentials in Google Cloud Console)
# Use Desktop app type. Authorized redirect URI in GCP: http://localhost:8080/api/calendar/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/calendar/auth/google/callback

# Coach / omni-ai (compose sets AI_URL on the gateway automatically; for local gateway see Makefile run-gateway / make run-ai)
# Gateway startup probes omni-ai /health unless AI_SKIP_HEALTHCHECK=1
# Google Gemini — Coach chat (AI Studio / Vertex: create key in Google AI Studio)
GEMINI_API_KEY=
# Primary model (default: gemini-2.5-flash-lite). Unversioned ids may 404 on v1beta — see AI Studio model list.
# GEMINI_MODEL=
# Fallback chain after primary: unset = gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-flash-lite (comma-separated).
# Set to empty to disable fallbacks. Free-tier quotas are often per-model; fallbacks spread load.
# GEMINI_MODEL_FALLBACKS=
